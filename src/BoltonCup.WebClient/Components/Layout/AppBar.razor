<MudAppBar Elevation="1" ToolBarClass="d-flex flex-row align-center">
    <a href="/" style="height: 100%">
        <BoltonCupLogo Height="64" />
    </a>
    
    <MudHidden Breakpoint="Breakpoint.MdAndUp" Invert>
        @foreach (var navLink in _navLinks)
        {
            <MudButton Href="@navLink.Href" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Large">@navLink.Title</MudButton>
        }
        @if (_moreNavLinks.Any())
        {
            <MudMenu Label="More" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Large" EndIcon="@Icons.Material.Rounded.KeyboardArrowDown">
                <MudList T="string">
                    @foreach (var navLink in _moreNavLinks)
                    {
                        <MudListItem Text="@navLink.Title" Icon="@navLink.Icon" Href="@navLink.Href" />
                    }
                </MudList>
            </MudMenu>
        }
        <MudSpacer />
        <UserMenu />
    </MudHidden>
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudSpacer />
        <MudIconButton OnClick="OpenDrawer" Icon="@Icons.Material.Rounded.Menu" Variant="Variant.Text" Color="Color.Inherit" />
        <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="1" Variant="DrawerVariant.Temporary" Width="100%">
            <MudPaper Class="d-flex flex-row align-center px-2 border-solid border-b" Elevation="0" Width="100%" Height="64px" Square>
                <a href="/" onclick="location.reload()" style="height: 100%">
                    <BoltonCupLogo Height="64" />
                </a>
                <MudSpacer />
                <MudIconButton OnClick="CloseDrawer" Icon="@Icons.Material.Rounded.Close" Variant="Variant.Text" Color="Color.Inherit" />
            </MudPaper>
            <MudNavMenu Class="mud-width-full" Color="Color.Primary" Margin="Margin.Normal" Rounded Bordered>
                @foreach (var navLink in _navLinks)
                {
                    @RenderNavLink(navLink)
                }
                @if (_moreNavLinks.Any())
                {
                    <MudNavGroup Title="More" Expanded>
                        @foreach (var navLink in _moreNavLinks)
                        {
                            @RenderNavLink(navLink)
                        }
                    </MudNavGroup>
                }
            </MudNavMenu>
            <MudSpacer />
            <UserMenu EndIcon="@Icons.Material.Rounded.KeyboardArrowUp" OnItemClick="CloseDrawer" Color="Color.Primary" Variant="Variant.Filled" />
        </MudDrawer>
    </MudHidden>
</MudAppBar>


@code{
    
    private readonly List<NavLinkItem> _navLinks =
    [
        new("Home", "/", Icons.Material.Rounded.Home, NavLinkMatch.All),
        new("Tournaments", "/tournaments", Icons.Material.Rounded.Stadium),
        new("Teams", "/teams", Icons.Material.Rounded.Groups),
        new("Schedule", "/schedule", Icons.Material.Rounded.CalendarMonth),
        new("Stats", "/stats", Icons.Material.Rounded.QueryStats)
    ];

    private readonly List<NavLinkItem> _moreNavLinks =
    [
        new("Bracket Challenge", "/bracket-challenges", Icons.Material.Rounded.AccountTree)
    ];
    
    private bool _drawerOpen;

    private void OpenDrawer() => _drawerOpen = true;
    private void CloseDrawer() => _drawerOpen = false;

    public record NavLinkItem(string Title, string Href, string Icon, NavLinkMatch Match = NavLinkMatch.Prefix);

    private RenderFragment RenderNavLink(NavLinkItem navLink)
        => @<MudNavLink Class="px-2" Href="@navLink.Href" Icon="@navLink.Icon" Match="navLink.Match">@navLink.Title</MudNavLink>;

}