@page "/tournaments/{TournamentId:int}/information"
@inject IBoltonCupApi BoltonCupApi

<PageTitle>Info | Bolton Cup</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    @if (_infoGuide is null)
    {
        <div class="d-flex flex-column align-center mb-8">
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="320px" Height="48px" />
        </div>
        @for (var i = 0; i < 12; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="100%" />
        }
    }
    else
    {
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-8"><b>@_infoGuide.Title</b></MudText>

        if (_infoGuide.Tournament?.IsRegistrationOpen ?? false)
        {
            <MudAlert Severity="Severity.Normal">Registration for @_infoGuide.Tournament.Name is live! <MudLink Color="Color.Info" Typo="Typo.body2" Href="@($"/tournaments/{_infoGuide.TournamentId}/register")"><b>Register now.</b></MudLink></MudAlert>
        }
        
        <MarkdownView Value="@_infoGuide.MarkdownContent" />
    }
</MudContainer>

@code {

    [Parameter]
    public int TournamentId { get; set; }
    
    private Sdk.InfoGuideSingleDto? _infoGuide;

    protected override async Task OnParametersSetAsync()
    {
        if (TournamentId != _infoGuide?.TournamentId)
            _infoGuide = await BoltonCupApi.GetInfoGuideByTournamentIdAsync(TournamentId);
    }

}