@page "/bracket-challenges"
@attribute [Sitemap(SitemapChangeFrequency.Monthly, Priority = 0.8f, LastModified = "2026-04-15")]
@inject IBoltonCupApi BoltonCupApi

<PageTitle>Bracket Challenges | Bolton Cup</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-1 py-2" Gutters="false">
    <div class="mt-6 mb-1 ml-2">
        <MudText Typo="Typo.h5"><b>Bracket Challenges</b></MudText>
    </div>
    
    <MudGrid Spacing="3">
        @foreach (var bracketChallenge in _bracketChallenges)
        {
            var registerText = bracketChallenge.IsOpen ? "Register" : "Closed";
            <MudItem xs="12">
                <MudPaper Class="d-flex flex-row align-center gap-3 px-1 py-8" Width="100%" Height="160px" Elevation="0" Outlined>
                    @* <div class="d-flex align-center justify-center mud-full-height" style="width: 120px"> *@
                    @*     <MudImage Src="@bracketChallenge.Logo" Alt="@bracketChallenge.Name" Height="80"/> *@
                    @* </div> *@
                    <div class="d-flex flex-column align-start justify-space-between">
                        <MudText Typo="Typo.h6"><b>@bracketChallenge.Title</b></MudText>
                        @* <DateRangeChip Start="bracketChallenge.StartDate" End="bracketChallenge.EndDate"/> *@
                        <div class="d-flex flex-row align-center gap-3 flex-wrap">
                            <MudButton
                                Color="Color.Secondary"
                                Href="@($"/bracket-challenges/{bracketChallenge.Id}/register")"
                                Disabled="!bracketChallenge.IsOpen">@registerText</MudButton>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {

    private List<Sdk.BracketChallengeDto> _bracketChallenges = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var bracketChallengeList = await BoltonCupApi.GetBracketChallengesAsync();
        _bracketChallenges = bracketChallengeList.Items.ToList();
    }

}