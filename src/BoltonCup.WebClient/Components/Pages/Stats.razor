@page "/stats"
@attribute [Sitemap(SitemapChangeFrequency.Yearly, LastModified = "2026-02-01")]

<PageTitle>Statistics | Bolton Cup</PageTitle>
<HeadContent>
    <meta name="description" content="The official source for Bolton Cup Stats including skater and goalie stats.">
</HeadContent>

<MudContainer MaxWidth="MaxWidth.Large" Class="my-4" Gutters="false">
    <MudText Typo="Typo.h6" Class="ml-4">Statistics</MudText>
    <MudTabs Rounded KeepPanelsAlive>
        <MudTabPanel Text="Skaters">
            <SkaterStatsDataGrid />
        </MudTabPanel>
        <MudTabPanel Text="Goalies">
            <GoalieStatsDataGrid />
        </MudTabPanel>
    </MudTabs>
</MudContainer>
