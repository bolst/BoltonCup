@page "/"
@attribute [Sitemap(SitemapChangeFrequency.Monthly, Priority = 0.8f, LastModified = "2026-02-01")]
@inject IBoltonCupApi BoltonCupApi

<PageTitle>Bolton Cup</PageTitle>


<MudContainer MaxWidth="MaxWidth.Large" Gutters="false">
    
    <div class="home-banner-background">
        <div class="d-flex flex-column align-center justify-center gap-6 mud-width-full px-2" style="height: 500px">
            <div class="d-flex flex-row align-center">
                @if (_tournament is not null)
                {
                    <Countdown To="@_tournament.StartDate"/>
                }
            </div>
            @if (_tournament?.IsRegistrationOpen == true)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                    Registration for @_tournament.Name is live! 
                    <MudLink Underline="Underline.Always" Typo="Typo.body2" Href="@($"/tournaments/{_tournament.Id}/register")">
                        <b>Register now.</b>
                    </MudLink>
                </MudAlert>
            }
        </div>
    </div>
    
    <Highlight Title="2025 Leaders" Href="stats">
        <MudGrid>
            <MudItem xs="12" md="6" lg="3">
                <TopPlayers Label="Points" TournamentId="2" SkaterCategory="x => x.Points" Descending/>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <TopPlayers Label="Goals" TournamentId="2" SkaterCategory="x => x.Goals" Descending/>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <TopPlayers Label="PIM" TournamentId="2" SkaterCategory="x => x.PenaltyMinutes" Descending/>
            </MudItem>
            <MudItem xs="12" md="6" lg="3">
                <TopPlayers Label="GAA" TournamentId="2" GoalieCategory="x => x.GoalsAgainstAverage"/>
            </MudItem>
        </MudGrid>
    </Highlight>

    @if (false)
    {
        <Highlight Title="Must Watch" Href="video" Class="d-flex flex-row align-start justify-space-evenly gap-3">
            <MudSkeleton Height="225px" Width="400px"/>
            <MudSkeleton Height="225px" Width="400px"/>
            <MudSkeleton Height="225px" Width="400px"/>
            <MudSkeleton Height="225px" Width="400px"/>
        </Highlight>
    }
</MudContainer>

@code {

    private static Sdk.TournamentSingleDto? _tournament;

    protected override async Task OnInitializedAsync()
    {
        // TODO: dont hardcode this
        _tournament ??= await BoltonCupApi.GetTournamentByIdAsync(3);
        await InvokeAsync(StateHasChanged);
    }

}