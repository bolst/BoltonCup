@page "/profile"
@using BoltonCup.Sdk
@inject IBoltonCupApi BoltonCupApi
@inject ISnackbar Snackbar
@attribute [Authorize]

<PageTitle>Profile | Bolton Cup</PageTitle>

@if (_accountInfo is not null)
{
    <MudContainer Class="pb-4" MaxWidth="MaxWidth.Large">
        <MudContainer MaxWidth="MaxWidth.Medium" Gutters="false">
            <div class="action-shot-container d-flex flex-row align-end">
                <BoltonCupImage Src="@_accountInfo.Banner" SrcChanged="UpdateBanner" Class="action-shot" ObjectFit="ObjectFit.Cover" Editable/>
            </div>
            <div class="d-flex flex-column align-center gap-3 mt-n20">
                <BoltonCupImage Src="@_accountInfo.Avatar" SrcChanged="UpdateAvatar" Height="160" Avatar Editable/>
            </div>
        </MudContainer>
        
        <MudDivider Class="my-4" />
        
        <MudGrid>
            <MudItem xs="12" md="6">
                <AccountInfoForm />
            </MudItem>
            <MudItem xs="12" md="6">
                <AccountTournamentList />
            </MudItem>
        </MudGrid>
        
    </MudContainer>
}

@code {
    
    private AccountDto? _accountInfo;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _accountInfo = await BoltonCupApi.GetMeAsync();
    }
    
    private async Task UpdateBanner(string? newSrc)
    {
        if (_accountInfo is null || string.IsNullOrEmpty(newSrc))
            return;
        try
        {
            await BoltonCupApi.UpdateBannerAsync(_accountInfo.Id, newSrc);
            _accountInfo.Banner = newSrc;
            Snackbar.Add("Your banner has been updated.", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch(Exception)
        {
            Snackbar.Add("Your image was uploaded but for some reason we could not assign it to you...", Severity.Error);
        }
    }

    private async Task UpdateAvatar(string? newSrc)
    {
        if (_accountInfo is null || string.IsNullOrEmpty(newSrc))
            return;
        try
        {
            await BoltonCupApi.UpdateAvatarAsync(_accountInfo.Id, newSrc);
            _accountInfo.Avatar = newSrc;
            Snackbar.Add("Your avatar has been updated.", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch(Exception _)
        {
            Snackbar.Add("Your image was uploaded but for some reason we could not assign it to you...", Severity.Error);
        }
    }
    
}