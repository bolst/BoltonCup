@page "/profile"
@using BoltonCup.Sdk
@inject IBoltonCupApi BoltonCupApi
@inject ISnackbar Snackbar
@attribute [Authorize]

<PageTitle>Profile | Bolton Cup</PageTitle>

@if (_userInfo is not null)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Gutters="false">
        <MudContainer MaxWidth="MaxWidth.Medium" Gutters="false">
            <div class="action-shot-container d-flex flex-row align-end">
                <BoltonCupImage Src="@_userInfo.Banner" SrcChanged="UpdateBanner" Class="action-shot" ObjectFit="ObjectFit.Cover" Editable/>
            </div>
            <div class="d-flex flex-column align-center gap-3 mt-n20">
                <BoltonCupImage Src="@_userInfo.Avatar" SrcChanged="UpdateAvatar" Height="160" Avatar Editable/>
            </div>
        </MudContainer>
        
    </MudContainer>
}

@code {

    private UserInfoDto? _userInfo;

    protected override async Task OnInitializedAsync()
    {
        _userInfo = await BoltonCupApi.GetMeAsync();
    }

    private async Task UpdateBanner(string? newSrc)
    {
        if (_userInfo?.Id is null || string.IsNullOrEmpty(newSrc))
            return;
        try
        {
            await BoltonCupApi.UpdateBannerAsync(_userInfo.Id.Value, newSrc);
            _userInfo.Banner = newSrc;
            Snackbar.Add("Your banner has been updated.", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch(Exception ex)
        {
            Snackbar.Add("Your image was uploaded but for some reason we could not assign it to you...", Severity.Error);
        }
    }

    private async Task UpdateAvatar(string? newSrc)
    {
        if (_userInfo?.Id is null || string.IsNullOrEmpty(newSrc))
            return;
        try
        {
            await BoltonCupApi.UpdateAvatarAsync(_userInfo.Id.Value, newSrc);
            _userInfo.Avatar = newSrc;
            Snackbar.Add("Your avatar has been updated.", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch(Exception ex)
        {
            Snackbar.Add("Your image was uploaded but for some reason we could not assign it to you...", Severity.Error);
        }
    }

}