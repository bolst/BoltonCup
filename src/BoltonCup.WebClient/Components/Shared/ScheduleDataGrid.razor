@using BoltonCup.Sdk
@inject IBoltonCupApi BoltonCupApi

<MudTable
    @ref="_dataGrid"
    T="Sdk.GameDto"
    ServerData="ServerReload"
    GroupBy="_groupDefinition"
    Breakpoint="Breakpoint.None"
    RowsPerPage="25"
    Elevation="0"
    Striped>
    <ToolBarContent>
        <div class="d-flex flex-row align-center gap-3 flex-wrap">
            <FilterToolbarField
                T="Sdk.TournamentDto?" Label="Tournament"
                Value="@_filter.Tournament" ValueChanged="OnFilterTournamentChange" OnApplyClicked="@_dataGrid.ReloadServerData"
                ToStringFunc="x => x?.Name">
                <TournamentFilter/>
            </FilterToolbarField>

            <FilterToolbarField
                T="Sdk.TeamDto?" Label="Team"
                @bind-Value="@_filter.Team" OnApplyClicked="@_dataGrid.ReloadServerData"
                ToStringFunc="x => x?.Name" Disabled="@(_filter.Tournament?.Id is null)">
                <TeamFilter TournamentId="@_filter.Tournament?.Id"/>
            </FilterToolbarField>
        </div>
    </ToolBarContent>
    <GroupHeaderTemplate>
            @switch (context.Key)
            {
                case TournamentGroupKey key:
                    <MudTh colspan="5">
                        <div class="d-flex flex-row align-center gap-1">
                            <MudText Typo="Typo.h6"><b>@key.TournamentName</b></MudText>
                            @if (!string.IsNullOrEmpty(key.TournamentLogo))
                            {
                                <MudImage Src="@key.TournamentLogo" Height="48" />
                            }
                        </div>
                    </MudTh>
                    break;
                case GameDayGroupKey key:
                    <MudTh colspan="5">
                        <MudText Typo="Typo.h6"><b>@key.GameTime</b></MudText>
                    </MudTh>
                    break;
                case GameStateGroupKey key:
                    <MudHidden Breakpoint="Breakpoint.MdAndUp" Invert>
                        <MudTh>
                            <div class="mud-width-full d-flex justify-center align-center">
                                <div style="width: 100px">&nbsp;</div>
                                <b>Matchup</b>
                            </div>
                        </MudTh>
                        <MudTh><b>@key.DetailHeaderName</b></MudTh>
                        <MudTh><b>Location</b></MudTh>
                        <MudTh></MudTh>
                    </MudHidden>
                    break;    
            }
    </GroupHeaderTemplate>
    <RowTemplate>
        <MudHidden Breakpoint="Breakpoint.MdAndUp" Invert>
            <MudTd DataLabel="Matchup">@MatchupCell(context)</MudTd>
            @switch (context.GameState)
            {
                case GameState.Pending:
                    <MudTd DataLabel="Time"><b>@context.GameTime.ToLocalTime().ToString("hh:mm tt")</b></MudTd>
                    break;
                case GameState.InProgress:
                    <MudTd DataLabel="Score">@GameScoreText(context)</MudTd>
                    break;
                case GameState.Completed:
                    <MudTd DataLabel="Result">@GameScoreText(context)</MudTd>
                    break;
            }
            <MudTd DataLabel="Location">@context.Venue <b>(@context.Rink)</b></MudTd>
            <MudTd>
                <MudButtonGroup>
                    <MudBadge Color="Color.Error" Visible="@(context.GameState == GameState.InProgress)" Dot>
                        <MudButton Href="@($"/games/{context.Id}")" StartIcon="@Icons.Material.Filled.SportsHockey" IconColor="Color.Info" Color="Color.Info">Gamecenter</MudButton>
                    </MudBadge>
                </MudButtonGroup>
            </MudTd>
        </MudHidden>
        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert>
            <div class="d-flex flex-column align-center mud-width-full py-2 gap-3 border-b mud-border-lines-default">
                <div class="d-flex flex-row align-center justify-space-between mud-width-full">
                    <div style="width: 36px"></div>
                    @GameScoreText(context)
                    <MudMenu Style="width: 36px" Icon="@Icons.Material.Rounded.MoreVert" AnchorOrigin="Origin.CenterLeft" TransformOrigin="Origin.CenterRight" Color="Color.Info" Size="Size.Small" Dense>
                        <MudMenuItem Href="@($"/games/{context.Id}")" Icon="@Icons.Material.Filled.SportsHockey" IconColor="Color.Info">Gamecenter</MudMenuItem>
                    </MudMenu>
                </div>
                @MatchupCell(context)
                <MudText Typo="Typo.caption"><b>@context.GameTime.ToLocalTime().ToString("hh:mm tt")</b></MudText>
                <MudText>@context.Venue <b>(@context.Rink)</b></MudText>
            </div>
        </MudHidden>
    </RowTemplate>
    <PagerContent>
        <MudTablePager HideRowsPerPage/>
    </PagerContent>
</MudTable>

@code {

    private MudTable<Sdk.GameDto> _dataGrid = null!;

    private readonly ScheduleFilterModel _filter = new();

    private readonly TableGroupDefinition<Sdk.GameDto> _groupDefinition = new()
    {
        GroupName = "Tournament",
        Indentation = true,
        Expandable = false,
        Selector = e => new TournamentGroupKey(e),
        InnerGroup = new TableGroupDefinition<GameDto>
        {
            GroupName = "Date",
            Indentation = false,
            Expandable = false,
            Selector = e => new GameDayGroupKey(e),
            InnerGroup = new TableGroupDefinition<GameDto>
            {
                GroupName = "State",
                Indentation = false,
                Expandable = false,
                Selector = e => new GameStateGroupKey(e)
            }
        }
    };

    private async Task<TableData<Sdk.GameDto>> ServerReload(TableState state, CancellationToken cancellationToken)
    {
        var data = await BoltonCupApi.GetGamesAsync(
            tournamentId: _filter.Tournament?.Id,
            teamId: _filter.Team?.Id,
            page: state.Page + 1,
            size: state.PageSize,
            cancellationToken: cancellationToken
        );
        return new TableData<Sdk.GameDto> {
            Items = data.Items,
            TotalItems = data.Total,
        };
    }

    private Task OnFilterTournamentChange(Sdk.TournamentDto? tournament)
    {
        _filter.Tournament = tournament;
        _filter.Team = null;
        return _dataGrid.ReloadServerData();
    }

    private RenderFragment MatchupCell(Sdk.GameDto context)
        => @<div class="mud-width-full d-flex flex-row align-center justify-center gap-4">
            @MatchupSide(context.AwayTeam, context.AwayTeamPlaceholder, reverse: false)
            @@
            @MatchupSide(context.HomeTeam, context.HomeTeamPlaceholder, reverse: true)
        </div>;

    private RenderFragment MatchupSide(Sdk.TeamInGameDto? team, string? placeholder, bool reverse)
    {
        var direction = reverse ? "flex-row-reverse" : "flex-row";
        return @<div class="d-flex @direction align-center justify-end gap-2" style="width: 100px">
            @if (team is not null)
            {
                <MudText Typo="Typo.body2"><b>@team.NameShort</b></MudText>
                <MudImage Src="@team.Logo" Height="48" Alt="@team.Abbreviation"/>
            }
            else if (!string.IsNullOrWhiteSpace(placeholder))
            {
                <MudText Typo="Typo.body2"><b>@placeholder</b></MudText>
            }
        </div>;
    }
    
    private RenderFragment GameScoreText(Sdk.GameDto context)
    {
        if (context.HomeTeam is null || context.AwayTeam is null)
            return _ => { };
        
        var (winner, loser) = context.HomeTeam.Goals >= context.AwayTeam.Goals
            ? (context.HomeTeam, context.AwayTeam)
            : (context.AwayTeam, context.HomeTeam);
        var style = context.GameState == GameState.InProgress
            ? "color: #16B011"
            : string.Empty;

        return @<MudText Typo="Typo.body2" Style="@style">
                   <b>@winner.Abbreviation @winner.Goals,</b> @loser.Abbreviation @loser.Goals
               </MudText>;
    }

    private record TournamentGroupKey
    {
        public string TournamentName { get; init; }
        public string? TournamentLogo { get; init; }
        
        public TournamentGroupKey(GameDto game)
        {
            TournamentName = game.Tournament.Name ?? string.Empty;
            TournamentLogo = game.Tournament.Logo;
        }
    }

    private record GameDayGroupKey
    {
        public string GameTime { get; init; }
        
        public GameDayGroupKey(GameDto game)
        {
            GameTime = game.GameTime.ToLocalTime().Date.ToLongDateString();
        }
    }

    private record GameStateGroupKey
    {
        public GameState GameState { get; init; }
        public string DetailHeaderName { get; init; }

        public GameStateGroupKey(GameDto game)
        {
            GameState = game.GameState;
            DetailHeaderName = game.GameState switch
            {
                GameState.InProgress => "Score",
                GameState.Completed => "Result",
                _ => "Time"
            };
        }
    }
    
    private class ScheduleFilterModel
    {
        public Sdk.TournamentDto? Tournament { get; set; }
        public Sdk.TeamDto? Team { get; set; }
    }

}