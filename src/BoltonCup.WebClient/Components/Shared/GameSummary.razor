@namespace BoltonCup.WebClient.Components.Shared


<div>
    @if (Game is not null)
    {
        if (Game.Stars.Any())
        {
            <div class="d-flex flex-row align-center px-1 py-2 mud-width-full">
                <MudText Typo="Typo.h6"><b>Three Stars of the Game</b></MudText>
            </div>

            <MudGrid>
                @foreach (var star in Game.Stars.Where(x => x.Player is not null && x.StarRank is >= 1 and <= 3).OrderBy(x => x.StarRank))
                {
                    var statLine = string.Join(" | ", star.Stats.Select(s => $"{s.Tag}: {s.Value}"));
                    <MudItem xs="12" sm="4">
                        <MudStack AlignItems="AlignItems.Center" Row>
                            <MudBadge Content="@star.StarRank.ToString()" BadgeClass="mr-n2 mt-n2" Origin="Origin.BottomLeft" Color="Color.Primary" Overlap="true" Bordered="true">
                                <MudAvatar Style="width: 64px; height: 64px">
                                    <MudImage Src="@star.Player.ProfilePicture" Alt="@star.Player.FullName"/>
                                </MudAvatar>
                            </MudBadge>
                            <div class="d-flex flex-column">
                                <PlayerLink Player="@star.Player" ToStringFunc="@(x => x!.FirstName[..1] + ". " + x.LastName)"/>
                                <MudText Typo="Typo.caption">@star.Player.JerseyNumberLabel | @star.Player.Position</MudText>
                                <MudText Typo="Typo.caption">@statLine</MudText>
                            </div>
                        </MudStack>
                    </MudItem>
                }
            </MudGrid>
        }

        if (Game.Highlights.Any())
        {
            <div class="d-flex flex-row align-center px-1 py-2 mud-width-full">
                <MudText Typo="Typo.h6"><b>Highlights</b></MudText>
            </div>
            
            <MudGrid>
                @foreach (var highlight in Game.Highlights.Take(3))
                {
                    <MudItem xs="12" md="4">
                        <iframe style="width: 100%; height: auto"
                                src="@($"{highlight.VideoUrl}?vq=hd720")" title="@highlight.Title" 
                                frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
                    </MudItem>
                }
            </MudGrid>
        }
    }
</div>


@code {

    [Parameter]
    [EditorRequired]
    public Sdk.GameSingleDto? Game { get; set; }

}