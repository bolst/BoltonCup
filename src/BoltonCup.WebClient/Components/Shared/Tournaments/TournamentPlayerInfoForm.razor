@using System.ComponentModel.DataAnnotations
@namespace BoltonCup.WebClient.Components.Shared
@inject IBoltonCupApi BoltonCupApi
@inject ISnackbar Snackbar

<AuthorizeView Context="_">
    <Authorized>
        @if (!_loaded)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="320px" Width="100%" />
        }
        else if (!_isInTournament)
        {
            <MudAlert Severity="Severity.Error">You are not registered for this tournament!</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.h6" Class="mb-1"><b>Game Availability</b></MudText>
            @if (_games.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    No games have been scheduled for this tournament yet.
                </MudAlert>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">Let your team know whether you can make each game.</MudText>
                <MudStack Spacing="2" Class="mb-4">
                    @foreach (var game in _games)
                    {
                        <MudPaper Class="d-flex flex-wrap align-center justify-space-between gap-2 pa-3" Outlined>
                            <div>
                                <MudText Typo="Typo.subtitle2">
                                    @GetGameTitle(game)
                                </MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @game.GameTime.ToLocalTime().ToString("ddd MMM d, h:mm tt")@(string.IsNullOrWhiteSpace(game.Venue) ? "" : $" · {game.Venue}")
                                </MudText>
                            </div>
                            <MudToggleGroup T="string"
                                            Value="@GetAvailability(game.Id)"
                                            ValueChanged="@(v => SetAvailability(game.Id, v))"
                                            Size="Size.Small"
                                            Color="Color.Primary"
                                            CheckMark
                                            FixedContent
                                            SelectionMode="SelectionMode.SingleSelection">
                                <MudToggleItem Value="@("In")" Text="In" />
                                <MudToggleItem Value="@("Maybe")" Text="Maybe" />
                                <MudToggleItem Value="@("Out")" Text="Out" />
                            </MudToggleGroup>
                        </MudPaper>
                    }
                </MudStack>
            }

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.h6" Class="mb-1"><b>Song Request</b></MudText>
            <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">Search for one song you'd like played at the tournament.</MudText>
            <SongPickerField Label="Song request"
                             Value="_selectedTrack"
                             ValueChanged="OnTrackChanged"
                             Class="mb-4" />

            @if (_managedTeam is { } managedTeam)
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.h6" Class="mb-1"><b>Team Music — @managedTeam.TeamName</b></MudText>
                <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">As GM, pick the songs that play when your team scores and wins.</MudText>
                <SongPickerField Label="Goal song"
                                 Value="_goalSong"
                                 ValueChanged="@(track => _goalSong = track)"
                                 Class="mb-3" />
                <SongPickerField Label="Win song"
                                 Value="_winSong"
                                 ValueChanged="@(track => _winSong = track)"
                                 Class="mb-4" />
            }

            <div class="d-flex justify-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="Save"
                           Disabled="_saving"
                           StartIcon="@Icons.Material.Rounded.Save">
                    @(_saving ? "Saving..." : "Save")
                </MudButton>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <MudAlert Severity="Severity.Error">Sorry! You are not authorized to view this.</MudAlert>
    </NotAuthorized>
</AuthorizeView>

@code {

    [Parameter]
    [EditorRequired]
    public int TournamentId { get; set; }

    private int? _tournamentId;
    private bool _isInTournament;
    private bool _loaded;
    private bool _saving;
    private IReadOnlyList<Sdk.GameDto> _games = [];
    private readonly Dictionary<int, string> _availability = new();
    private Sdk.MusicTrackDto? _selectedTrack;
    private Sdk.ManagedTeamDto? _managedTeam;
    private Sdk.MusicTrackDto? _goalSong;
    private Sdk.MusicTrackDto? _winSong;

    protected override async Task OnParametersSetAsync()
    {
        if (TournamentId == _tournamentId)
            return;
        _tournamentId = TournamentId;

        try
        {
            var dto = await BoltonCupApi.GetMyTournamentPlayerInfoAsync(TournamentId);
            _games = dto.Games is { } games ? games.ToList() : [];
            _availability.Clear();
            foreach (var availability in dto.GameAvailability)
            {
                _availability[availability.GameId] = availability.Availability.ToString();
            }
            _selectedTrack = dto.Song;
            _managedTeam = dto.ManagedTeam;
            _goalSong = dto.ManagedTeam?.GoalSong;
            _winSong = dto.ManagedTeam?.WinSong;
            _isInTournament = true;
        }
        catch (Sdk.ApiException<Sdk.BoltonCupProblemDetails> e)
            when (e.Result.Type == ErrorTypes.Tournaments.AccountNotRegistered)
        {
            _isInTournament = false;
        }
        finally
        {
            _loaded = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetGameTitle(Sdk.GameDto game)
    {
        var awayPlaceholder = string.IsNullOrWhiteSpace(game.AwayTeamPlaceholder) ? null : game.AwayTeamPlaceholder;
        var homePlaceholder = string.IsNullOrWhiteSpace(game.HomeTeamPlaceholder) ? null : game.HomeTeamPlaceholder;
        var awayName = game.AwayTeam?.NameShort ?? awayPlaceholder ?? "TBD";
        var homeName = game.HomeTeam?.NameShort ?? homePlaceholder ?? "TBD";
        if (game.AwayTeam is null || game.HomeTeam is null)
        {
            var gameType = game.GameType.ToString();
            return $"{awayName} vs. {homeName} ({gameType})";
        }
        return $"{awayName} vs. {homeName}";
    }

    private string? GetAvailability(int gameId)
        => _availability.GetValueOrDefault(gameId);

    private void SetAvailability(int gameId, string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            _availability.Remove(gameId);
        }
        else
        {
            _availability[gameId] = value;
        }
    }

    private void OnTrackChanged(Sdk.MusicTrackDto? track)
    {
        _selectedTrack = track;
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            await BoltonCupApi.UpdateMyTournamentPlayerInfoAsync(TournamentId, new Sdk.UpdateTournamentPlayerInfoRequest
            {
                GameAvailability = _availability
                    .Select(kvp => new Sdk.GameAvailabilityDto
                    {
                        GameId = kvp.Key,
                        Availability = Enum.Parse<Sdk.GameAvailability>(kvp.Value),
                    })
                    .ToList(),
                Song = _selectedTrack,
            });

            if (_managedTeam is { } managedTeam)
            {
                await BoltonCupApi.UpdateTeamSongsAsync(managedTeam.TeamId, new Sdk.UpdateTeamSongsRequest
                {
                    GoalSong = _goalSong,
                    WinSong = _winSong,
                });
            }

            Snackbar.Add("Your info has been saved.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Something went wrong saving your info.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

}
