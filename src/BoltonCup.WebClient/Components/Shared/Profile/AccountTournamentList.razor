@namespace BoltonCup.WebClient.Components.Shared
@inject IBoltonCupApi BoltonCupApi

<MudPaper Class="pa-4 d-flex flex-column gap-3" Elevation="0" Outlined>
    
    @foreach (var tournament in _openTournaments)
    {
        <MudPaper Class="pa-4 blue lighten-3 d-flex flex-column justify-space-evenly gap-3">
            <MudText Typo="Typo.button">Upcoming Tournament</MudText>
            <MudText Typo="Typo.h5"><b>@tournament.Name</b></MudText>
            <MudText Typo="Typo.subtitle1">@GetTournamentDateLabel(tournament)</MudText>
            @if (_userTournaments.All(t => t.Tournament.Id != tournament.Id))
            {
                <MudButton Href="@($"/tournaments/{tournament.Id}/register")" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Disabled="!tournament.IsRegistrationOpen" FullWidth>
                    Register now
                </MudButton>
            }
            else
            {
                <TournamentPlayerInfoButton TournamentId="tournament.Id" IsPlayerInfoOpen="tournament.IsPlayerInfoOpen" FullWidth Size="Size.Large" />
            }
        </MudPaper>
    }

    <MudText Typo="Typo.body2"><b>My Tournaments</b></MudText>

    <MudList T="string" Gutters Padding ReadOnly>
        @foreach (var (player, index) in _userTournaments.Select((player, i) => (player ,i)))
        {
            var color = index % 2 != 0 ? string.Empty : "gray lighten-3";
            var listImage = !string.IsNullOrWhiteSpace(player.Team?.Logo) ? player.Team.Logo : player.Tournament.Logo;
            <MudListItem T="string" Class="@color">
                <div class="d-flex flex-row align-center justify-space-between gap-3 flex-wrap" style="width: 100%">
                    <div class="d-flex flex-row align-center gap-3">
                        <div class="d-flex flex-column align-center" style="width: 64px">
                            <MudImage Src="@listImage" Height="48"/>
                        </div>
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body1">@player.Tournament.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@(player.Team?.Name ?? "Free agent")</MudText>
                        </div>
                    </div>

                    @if (player.Tournament.IsPlayerInfoOpen)
                    {
                        <MudButton Href="@($"/tournaments/{player.Tournament.Id}/player-info")"
                                   Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                            Edit Player Info
                        </MudButton>
                    }

                    @if (player.Tournament.IsTradingOpen && (_isAdmin || _gmTournamentIds.Contains(player.Tournament.Id)))
                    {
                        <MudButton Href="@($"/tournaments/{player.Tournament.Id}/trade-hub")"
                                   Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                            Trade Hub
                        </MudButton>
                    }
                </div>
            </MudListItem>
        }
    </MudList>

</MudPaper>


@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private ICollection<Sdk.TournamentDto> _openTournaments = [];
    private ICollection<Sdk.AccountTournamentDto> _userTournaments = [];
    private HashSet<int> _gmTournamentIds = [];
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            _isAdmin = user.IsInRole("Admin");
            _gmTournamentIds = user.GetTournamentGmIds().ToHashSet();
        }

        await Task.WhenAll(
            GetOpenTournaments(),
            GetMyTournaments()
        );
    }

    private async Task GetOpenTournaments()
    {
        var openTournamentList = await BoltonCupApi.GetTournamentsAsync(registrationOpen: true, size: 3);
        _openTournaments = openTournamentList.Items;
    }
    
    private async Task GetMyTournaments()
    {
        _userTournaments = await BoltonCupApi.GetMyTournamentsAsync();
    }

    private string GetTournamentDateLabel(Sdk.TournamentDto tournament)
    {
        const string format = "m";
        return tournament switch
        {
            { StartDate: not null, EndDate: not null } => $"{tournament.StartDate.Value.ToString(format)} to {tournament.EndDate.Value.ToString(format)}",
            { StartDate: not null, EndDate: null} => $"{tournament.StartDate.Value.ToString(format)}",
            { StartDate: null, EndDate: not null} => $"Ends {tournament.EndDate.Value.ToString(format)}",
            _ => "Date TBA",
        };
    }

}