@using BoltonCup.Sdk
@namespace BoltonCup.WebClient.Components.Shared


<div class="d-flex flex-column gap-2">
    @if (Game is { HomeTeam: not null, AwayTeam: not null })
    {
        <GameSummarySection Title="Players to Watch"
                            Visible="@(Game.GameState == GameState.Pending)">
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <div class="d-flex flex-row justify-space-between mud-width-full">
                        <MudImage Src="@Game.AwayTeam.Logo" Height="36"/>
                        <MudImage Src="@Game.HomeTeam.Logo" Height="36"/>
                    </div>
                </MudItem>
                @foreach (var playersToWatch in Game.PlayersToWatch)
                {
                    if (playersToWatch is not { HomeLeader: not null, AwayLeader: not null } context)
                    {
                        continue;
                    }
                    var total = context.HomeLeader.StatValue + context.AwayLeader.StatValue;
                    var awayStatPctg = context.AwayLeader.StatValue / total;
                    var homeStatPctg = 1 - awayStatPctg;
                    <MudItem xs="4">
                        <div class="d-flex flex-row align-center gap-3">
                            <MudAvatar>
                                <MudImage Src="@context.AwayLeader.ProfilePicture" Alt="@context.AwayLeader.FullName"/>
                            </MudAvatar>
                            <MudLink Href="@($"/players/{context.AwayLeader.PlayerId}")" Underline="Underline.None">
                                <div class="d-flex flex-column align-start">
                                    <MudText Typo="Typo.caption">@context.AwayLeader.FirstName</MudText>
                                    <MudText Typo="Typo.h6" Style="line-height: 1rem">@context.AwayLeader.LastName</MudText>
                                    <MudText Typo="Typo.caption">@context.AwayLeader.JerseyNumberLabel</MudText>
                                </div>
                            </MudLink>
                        </div>
                    </MudItem>
                    <MudItem xs="4">
                        <div class="d-flex flex-row align-center justify-space-between">
                            <MudText Typo="Typo.h4"><b>@context.AwayLeader.StatString</b></MudText>
                            <MudText>@context.Title</MudText>
                            <MudText Typo="Typo.h4"><b>@context.HomeLeader.StatString</b></MudText>
                        </div>
                    </MudItem>
                    <MudItem xs="4">
                        <div class="d-flex flex-row-reverse align-center gap-3">
                            <MudAvatar>
                                <MudImage Src="@context.HomeLeader.ProfilePicture" Alt="@context.HomeLeader.FullName"/>
                            </MudAvatar>
                            <MudLink Href="@($"/players/{context.HomeLeader.PlayerId}")" Underline="Underline.None">
                                <div class="d-flex flex-column align-end">
                                    <MudText Typo="Typo.caption">@context.HomeLeader.FirstName</MudText>
                                    <MudText Typo="Typo.h6" Style="line-height: 1rem">@context.HomeLeader.LastName</MudText>
                                    <MudText Typo="Typo.caption">@context.HomeLeader.JerseyNumberLabel</MudText>
                                </div>
                            </MudLink>
                        </div>
                    </MudItem>
                    <MudItem xs="12">
                        <div class="d-flex flex-row align-center gap-2 mud-width-full">
                            <div class="d-flex" style="@($"flex: {awayStatPctg}; background-color: {Game.AwayTeam.PrimaryColorHex}")">
                                <div class="mud-width-full" style="height: 8px"></div>
                            </div>
                            <div class="d-flex" style="@($"flex: {homeStatPctg}; background-color: {Game.HomeTeam.PrimaryColorHex}")">
                                <div class="mud-width-full" style="height: 8px"></div>
                            </div>
                        </div>
                    </MudItem>
                    <MudItem xs="12">
                        &nbsp;
                    </MudItem>
                }
            </MudGrid>
        </GameSummarySection>
        
        <GameSummarySection Title="Three Stars of the Game" 
                            Visible="@(Game.GameState == GameState.Completed && Game.Stars.Any())">
            <MudGrid>
                @foreach (var star in Game.Stars.Where(x => x.StarRank is >= 1 and <= 3).OrderBy(x => x.StarRank))
                {
                    var statLine = string.Join(" | ", star.Stats.Select(s => $"{s.Tag}: {s.Value}"));
                    <MudItem xs="12" sm="4">
                        <MudStack AlignItems="AlignItems.Center" Row>
                            <MudBadge Content="@star.StarRank.ToString()" BadgeClass="mr-n2 mt-n2" Origin="Origin.BottomLeft" Color="Color.Primary" Overlap="true" Bordered="true">
                                <MudAvatar Style="width: 64px; height: 64px">
                                    <MudImage Src="@star.Player.ProfilePicture" Alt="@star.Player.FullName"/>
                                </MudAvatar>
                            </MudBadge>
                            <div class="d-flex flex-column">
                                <PlayerLink Player="@star.Player" ToStringFunc="@(x => x!.FirstName[..1] + ". " + x.LastName)"/>
                                <MudText Typo="Typo.caption">@star.Player.JerseyNumberLabel | @star.Player.Position</MudText>
                                <MudText Typo="Typo.caption">@statLine</MudText>
                            </div>
                        </MudStack>
                    </MudItem>
                }
            </MudGrid>
        </GameSummarySection>
        
        <GameSummarySection Title="Scoring" 
                            Visible="@(Game.GameState != GameState.Pending && Game.Goals.Any())">
            @foreach (var periodGoals in Game.Goals.GroupBy(g => g.PeriodLabel))
            {
                <MudText Typo="Typo.subtitle1"><b>@periodGoals.Key</b></MudText>

                <MudStack Spacing="1" Class="mud-width-full mb-2">
                    @foreach (var goal in periodGoals)
                    {
                        var assists = "Unassisted";
                        if (goal.PrimaryAssist is not null)
                        {
                            assists = goal.PrimaryAssist.FirstName[..1] + ". " + goal.PrimaryAssist.LastName;
                            if (goal.SecondaryAssist is not null)
                            {
                                assists += ", " + goal.SecondaryAssist.FirstName[..1] + ". " + goal.SecondaryAssist.LastName;
                            }
                        }
                        <MudPaper Class="d-flex flex-row align-center justify-space-between flex-wrap gap-3 px-4" Width="100%" MinHeight="120px" Elevation="0" Outlined Square>
                            <MudGrid>
                                <MudItem xs="8" Class="d-flex flex-row align-center gap-3">
                                    <MudAvatar Style="width: 64px; height: 64px">
                                        <MudImage Src="@goal.Scorer.ProfilePicture" Alt="@goal.Scorer.FullName"/>
                                    </MudAvatar>
                                    <div class="d-flex flex-column align-start justify-space-between">
                                        <PlayerLink Player="@goal.Scorer" Typo="Typo.body1"/>
                                        <div class="d-flex flex-row align-center gap-1">
                                            <MudImage Src="@(goal.TeamId == Game.HomeTeam.Id ? Game.HomeTeam.Logo : Game.AwayTeam.Logo)" Height="24"/>
                                            <MudText Typo="Typo.body2">@assists</MudText>
                                        </div>
                                    </div>
                                </MudItem>
                                <MudItem xs="1" sm="2"></MudItem>
                                <MudItem xs="3" sm="2">
                                    <MudGrid>
                                        @* <MudItem xs="4"></MudItem> *@
                                        @* <MudItem xs="4"></MudItem> *@
                                        <MudItem xs="12">
                                            <div class="d-flex flex-column align-center gap-1 gray lighten-3 pa-2">
                                                <MudText Typo="Typo.subtitle2">@goal.TimeString</MudText>
                                                <MudText Typo="Typo.caption">Time</MudText>
                                            </div>
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                            </MudGrid>
                            
                        </MudPaper>
                    }
                </MudStack>
            }
        </GameSummarySection>
        
        <GameSummarySection 
            Title="Highlights" 
            Visible="@(Game.GameState != GameState.Pending && Game.Highlights.Any())">
            <MudGrid>
                @foreach (var highlight in Game.Highlights.Take(3))
                {
                    <MudItem xs="12" md="4">
                        <VideoHighlight Highlight="@highlight" />
                    </MudItem>
                }
            </MudGrid>
        </GameSummarySection>

        <GameSummarySection Title="Penalties" 
                            Visible="@(Game.GameState != GameState.Pending && Game.Penalties.Any())">
            <MudSimpleTable Elevation="0" Striped Square>
                @foreach (var periodPenalties in Game.Penalties.GroupBy(p => p.PeriodLabel))
                {
                    <colgroup>
                        <col span="2" style="width: 75px" />
                        <col class="border-l mud-border-lines-default mud-width-full" />
                    </colgroup>
                    <thead>
                    <tr>
                        <th colspan="3">
                            <MudText Typo="Typo.subtitle1"><b>@periodPenalties.Key</b></MudText>
                        </th>
                    </tr>
                    <tr>
                        <th>Team</th>
                        <th>Time</th>
                        <th>Penalty</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var penalty in periodPenalties)
                    {
                        <tr>
                            <td>
                                <MudImage Src="@(penalty.TeamId == Game.HomeTeam.Id ? Game.HomeTeam.Logo : Game.AwayTeam.Logo)" Height="24" />
                            </td>
                            <td>@penalty.TimeString</td>
                            <td>@penalty.Player.FullName (@penalty.Player.JerseyNumberLabel) @penalty.DurationMins minutes for @penalty.Infraction</td>
                        </tr>
                    }
                    </tbody>
                }
            </MudSimpleTable>
        </GameSummarySection>
    }
</div>


@code {

    [Parameter]
    [EditorRequired]
    public Sdk.GameSingleDto? Game { get; set; }
    
    private static readonly TableGroupDefinition<Sdk.PenaltyBriefDto> _penaltiesGroupDefinition = new()
    {
        GroupName = "Period",
        Indentation = false,
        Expandable = false,
        Selector = e => e.PeriodLabel ?? string.Empty,
    };
}