@namespace BoltonCup.WebClient.Components.Shared
@inject IBoltonCupApi BoltonCupApi

@if (_loading)
{
    
}
else
{
        
    if (_game is not null)
    {
        <div>
            <div class="d-flex flex-row align-center px-1 py-2 mud-width-full">
                <MudText Typo="Typo.h6"><b>Game Sheet</b></MudText>
                <MudSpacer />
                <MudToggleGroup T="Sdk.TeamInGameDto" Value="_selectedTeam" ValueChanged="SetSelectedTeam" Size="Size.Small">
                    @if (_game.AwayTeam is not null)
                    {
                        <MudToggleItem Value="_game.AwayTeam" Text="@_game.AwayTeam.NameShort"/>
                    }
                    
                    @if (_game.HomeTeam is not null)
                    {
                        <MudToggleItem Value="_game.HomeTeam" Text="@_game.HomeTeam.NameShort"/>
                    }
                </MudToggleGroup>
            </div>
            <MudSimpleTable Elevation="0" Striped Square>
                <thead>
                <tr>
                    <th>#</th>
                    <th>FORWARDS</th>
                    <th>G</th>
                    <th>A</th>
                    <th>P</th>
                    <th>PIM</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var forward in _forwardLogs)
                {
                    <tr>
                        <td>@forward.JerseyNumber</td>
                        <td><PlayerLink PlayerId="@forward.PlayerId" Label="@GetFormattedPlayerName(forward.FirstName, forward.LastName)" /></td>

                        <td>@forward.Goals</td>
                        <td>@forward.Assists</td>
                        <td>@forward.Points</td>
                        <td>@forward.PenaltyMinutes</td>
                    </tr>
                }
                </tbody>
                <thead class="border-t-4 mud-border-lines-default">
                <tr>
                    <th>#</th>
                    <th>DEFENSE</th>
                    <th>G</th>
                    <th>A</th>
                    <th>P</th>
                    <th>PIM</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var defense in _defenseLogs)
                {
                    <tr>
                        <td>@defense.JerseyNumber</td>
                        <td><PlayerLink PlayerId="@defense.PlayerId" Label="@GetFormattedPlayerName(defense.FirstName, defense.LastName)" /></td>

                        <td>@defense.Goals</td>
                        <td>@defense.Assists</td>
                        <td>@defense.Points</td>
                        <td>@defense.PenaltyMinutes</td>
                    </tr>
                }
                </tbody>
                <thead class="border-t-4 mud-border-lines-default">
                <tr>
                    <th>#</th>
                    <th>GOALIE</th>
                    <th>GA</th>
                    <th>W</th>
                    <th>SO</th>
                    <th>PIM</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var goalie in _goalieLogs)
                {
                    <tr>
                        <td>@goalie.JerseyNumber</td>
                        <td><PlayerLink PlayerId="@goalie.PlayerId" Label="@GetFormattedPlayerName(goalie.FirstName, goalie.LastName)" /></td>
                        <td>@goalie.GoalsAgainst</td>
                        <td>
                            @if (goalie.Wins > 0)
                            {
                                <MudIcon Icon="@Icons.Material.Rounded.CheckBox" Color="Color.Success" Size="Size.Small"/>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Rounded.Cancel" Color="Color.Error" Size="Size.Small"/>
                            }
                        </td>
                        <td>
                            @if (goalie.Shutouts > 0)
                            {
                                <MudIcon Icon="@Icons.Material.Rounded.CheckBox" Color="Color.Success" Size="Size.Small"/>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Rounded.Cancel" Color="Color.Error" Size="Size.Small"/>
                            }
                        </td>
                        <td>@goalie.PenaltyMinutes</td>
                    </tr>
                }
                </tbody>
            </MudSimpleTable>
        </div>
    }
}


@code {

    [Parameter, EditorRequired]
    public required Sdk.GameSingleDto Game { get; set; }
    
    private Sdk.GameSingleDto? _game;

    private bool _loading;

    private Sdk.SkaterStatDtoIPagedList? _skaterLog;
    private Sdk.GoalieStatDtoIPagedList? _goalieLog;
    
    private Sdk.TeamInGameDto? _selectedTeam;
    private List<Sdk.SkaterStatDto> _forwardLogs = [];
    private List<Sdk.SkaterStatDto> _defenseLogs = [];
    private List<Sdk.GoalieStatDto> _goalieLogs = [];

    protected override async Task OnParametersSetAsync()
    {
        if (Game.Id == _game?.Id)
            return;
        _game = Game;

        
        _loading = true;
        await Task.WhenAll(GetAndSetSkaterLogsAsync(), GetAndSetGoalieLogsAsync());
        SetSelectedTeam(_game.AwayTeam);
        _loading = false;
        StateHasChanged();
    }

    private async Task GetAndSetSkaterLogsAsync()
    {
        _skaterLog = await BoltonCupApi.GetSkaterStatsAsync(gameId: Game.Id);
    }
    
    private async Task GetAndSetGoalieLogsAsync()
    {
        _goalieLog = await BoltonCupApi.GetGoalieStatsAsync(gameId: Game.Id);
    }

    private void SetSelectedTeam(Sdk.TeamInGameDto? team)
    {
        _selectedTeam = team;
        if (_selectedTeam is null)
        {
            _forwardLogs = [];
            _defenseLogs = [];
            _goalieLogs = [];
            return;
        }

        _forwardLogs = (_skaterLog?.Items ?? [])
            .Where(p => p.Position == "forward" && p.TeamId == _selectedTeam.Id)
            .ToList();
        _defenseLogs = (_skaterLog?.Items ?? [])
            .Where(p => p.Position == "defense" && p.TeamId == _selectedTeam.Id)
            .ToList();
        _goalieLogs = (_goalieLog?.Items ?? [])
            .Where(p => p.TeamId == _selectedTeam.Id)
            .ToList();
    }

    private string GetFormattedPlayerName(string firstName, string lastName)
    {
        var first = firstName.FirstOrDefault();
        return $"{first}. {lastName}";
    }
    
}