@page "/teams"
@inject ITeamService TeamService

<EntityDataGrid
    @ref="@_dataGrid"
    T="Team"
    NewItemFunc="NewItemFunc"
    SearchBy="x => x.Name"
    Comparer="_comparer">
    <Columns>
        <PropertyColumn Title="Team" Property="x => x.Name" />
        <PropertyColumn Title="Name (short)" Property="x => x.NameShort" />
        <PropertyColumn Title="Abbreviation" Property="x => x.Abbreviation" />
        <ImageColumn T="Team" Title="Logo" Property="x => x.Logo" OnImageUploaded="UpdateTeamLogo" />
        <ImageColumn T="Team" Title="Banner" Property="x => x.Banner" OnImageUploaded="UpdateTeamBanner" />
        <ColorPickerColumn Title="Primary" Property="x => x.PrimaryColorHex" />
        <ColorPickerColumn Title="Secondary" Property="x => x.SecondaryColorHex" />
        <ColorPickerColumn Title="Tertiary" Property="x => x.TertiaryColorHex" />
        <ForeignColumn Title="Tournament" Property="x => x.Tournament" PropertySetter="(game, tournament) => game.Tournament = tournament" 
                       EqualityComparer="new TournamentComparer()" ImageSrcFunc="t => t.Logo" />
    </Columns>
</EntityDataGrid>

@code {

    private EntityDataGrid<Team> _dataGrid = null!;
    private readonly TeamComparer _comparer = new();
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await _dataGrid.ExtendSortAsync("Tournament.StartDate", SortDirection.Descending, x => x.Tournament.StartDate);
    }
    
    private async Task<Team?> NewItemFunc()
    {
        return new Team
        {
            Name = "Detroit Red Wings",
            NameShort = "Red Wings",
            Abbreviation = "DRW",
            PrimaryColorHex = "#CE1126",
            SecondaryColorHex = "#FFFFFF"
        };
    }

    private async Task UpdateTeamLogo(ImageUploadResult<Team> result)
    {
        if (string.IsNullOrEmpty(result.NewKey)) 
            return;
        await TeamService.UpdateLogoAsync(result.Item.Id, result.NewKey);
    }
    
    private async Task UpdateTeamBanner(ImageUploadResult<Team> result)
    {
        if (string.IsNullOrEmpty(result.NewKey)) 
            return;
        await TeamService.UpdateBannerAsync(result.Item.Id, result.NewKey);
    }
    
}