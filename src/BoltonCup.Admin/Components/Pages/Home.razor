@page "/"


<EntityDataGrid
    T="TournamentRegistration"
    SearchBy="@(x => x.Account.FirstName + " " + x.Account.LastName)"
    ReadOnly
    >
    <Columns>
        <PropertyColumn Title="First" Property="x => x.Account.FirstName" />
        <PropertyColumn Title="Last" Property="x => x.Account.LastName" />
        <PropertyColumn Title="Current Step" Property="x => x.CurrentStep" />
        <PropertyColumn Title="Complete" Property="x => x.IsComplete">
            <CellTemplate>
                @if (context.Item.IsComplete)
                {
                    <MudIcon Icon="@Icons.Material.Rounded.Check" Color="Color.Success" Size="Size.Small" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Rounded.Cancel" Color="Color.Error" Size="Size.Small" />
                }
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Title="Current Step" Property="x => x.CreatedAt" Format="g" />
    </Columns>
</EntityDataGrid>