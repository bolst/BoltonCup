@page "/tournaments"
@inject ITournamentService TournamentService

<EntityDataGrid
    T="Tournament"
    NewItemFunc="NewItemFunc"
    SearchBy="x => x.Name"
    Include="@(x => x.Include(p => p.Players))"
    Comparer="_comparer">
    <Columns>
        <PropertyColumn Title="Tournament" Property="x => x.Name" />
        <ImageColumn T="Tournament" Title="Logo" Property="x => x.Logo" OnImageUploaded="UpdateTournamentLogo" />
        <ImageColumn T="Tournament" Title="Background" Property="x => x.BackgroundImage" OnImageUploaded="UpdateTournamentBackgroundImage" />
        <TemplateColumn Title="Info">
            <EditTemplate>
                <TournamentInfoEditButton TournamentId="@context.Item.Id" />
            </EditTemplate>
        </TemplateColumn>
        <DatePickerColumn Title="Start" Property="x => x.StartDate" InitialDirection="SortDirection.Descending" />
        <DatePickerColumn Title="End" Property="x => x.EndDate" />
        <BoolColumn Title="Active?" Property="x => x.IsActive" />
        <BoolColumn Title="Registration Open?" Property="x => x.IsRegistrationOpen" />
        <BoolColumn Title="Payment Open" Property="x => x.IsPaymentOpen" />
        <BoolColumn Title="Player Info Open?" Property="x => x.IsPlayerInfoOpen" />
        <BoolColumn Title="Trading Open?" Property="x => x.IsTradingOpen" />
        <PropertyColumn Title="Skater Limit" Property="x => x.SkaterLimit" />
        <PropertyColumn Title="Goalie Limit" Property="x => x.GoalieLimit" />
        <PropertyColumn Title="Skater Registration Fee" Property="x => x.SkaterRegistrationFee" />
        <PropertyColumn Title="Goalie Registration Fee" Property="x => x.GoalieRegistrationFee" />
        <ForeignColumn Title="Winner" Property="x => x.WinningTeam"
                       EqualityComparer="new TeamComparer()!" ImageSrcFunc="t => t.Logo" />
        <ForeignColumn Title="Gallery" Property="x => x.Gallery" PropertySetter="(t, g) => { t.Gallery = g; t.GalleryId = g?.Id; }"
                       EqualityComparer="new GalleryComparer()!" Required="false"/>
        <BoolColumn Title="Stats Featured?" Property="x => x.IsStatsFeatured" />
        <PropertyColumn Title="Featured Stats Label" Property="x => x.FeaturedStatsLabel" Required />
    </Columns>
    <ChildRowContent>
        <div class="pa-2 d-flex flex-row align-center gap-1">
            <MudChip Href='@($"/tournaments/{context.Item.Id}/players")' Variant="Variant.Text" Color="Color.Info" Label="true">
                Players (@context.Item.Players.Count(p => p.Position != Core.Values.Position.Goalie) skaters, @context.Item.Players.Count(p => p.Position == Core.Values.Position.Goalie) goalies)
            </MudChip>
            
            <MudChip Href='@($"/tournaments/{context.Item.Id}/budget")' Variant="Variant.Text" Color="Color.Info" Label="true">
                Budget
            </MudChip>
            
            <MudChip Href='@($"/tournaments/{context.Item.Id}/sponsors")' Variant="Variant.Text" Color="Color.Info" Label="true">
                Sponsors
            </MudChip>

            <MudChip Href='@($"/tournaments/{context.Item.Id}/music")' Variant="Variant.Text" Color="Color.Info" Label="true">
                Music
            </MudChip>

            <MudChip Href='@($"/tournaments/{context.Item.Id}/player-info")' Variant="Variant.Text" Color="Color.Info" Label="true">
                Player Info
            </MudChip>
        </div>
    </ChildRowContent>
</EntityDataGrid>

@code {
    
    private readonly TournamentComparer _comparer = new();

    private async Task<Tournament?> NewItemFunc()
    {
        return new Tournament
        {
            Name = "New Tournament"
        };
    }
    
    private async Task UpdateTournamentLogo(ImageUploadResult<Tournament> result)
    {
        if (string.IsNullOrEmpty(result.NewKey))
            return;
        await TournamentService.UpdateLogoAsync(result.Item.Id, result.NewKey);
    }

    private async Task UpdateTournamentBackgroundImage(ImageUploadResult<Tournament> result)
    {
        if (string.IsNullOrEmpty(result.NewKey))
            return;
        await TournamentService.UpdateBackgroundImageAsync(result.Item.Id, result.NewKey);
    }

}