@page "/tournaments"
@inject ITournamentService TournamentService

<EntityDataGrid
    T="Tournament"
    NewItemFunc="NewItemFunc"
    SearchBy="x => x.Name"
    Include="@(x => x.Include(p => p.Players))"
    Comparer="_comparer">
    <Columns>
        <PropertyColumn Title="Tournament" Property="x => x.Name" />
        <ImageColumn T="Tournament" Title="Logo" Property="x => x.Logo" OnImageUploaded="UpdateTournamentLogo" />
        <TemplateColumn Title="Info">
            <EditTemplate>
                <TournamentInfoEditButton TournamentId="@context.Item.Id" />
            </EditTemplate>
        </TemplateColumn>
        <DatePickerColumn Title="Start" Property="x => x.StartDate" />
        <DatePickerColumn Title="End" Property="x => x.EndDate" />
        <BoolColumn Title="Active?" Property="x => x.IsActive" />
        <BoolColumn Title="Registration Open?" Property="x => x.IsRegistrationOpen" />
        <BoolColumn Title="Payment Open" Property="x => x.IsPaymentOpen" />
        <TemplateColumn Title="Players" Editable="false">
            <CellTemplate>
                <MudChip Href='@($"/tournaments/{context.Item.Id}/players")' Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Label="true">
                    @context.Item.Players.Count(p => p.Position != Core.Values.Position.Goalie)P
                    @context.Item.Players.Count(p => p.Position == Core.Values.Position.Goalie)G
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Title="Skater Limit" Property="x => x.SkaterLimit" />
        <PropertyColumn Title="Goalie Limit" Property="x => x.GoalieLimit" />
        <PropertyColumn Title="Skater Registration Fee" Property="x => x.SkaterRegistrationFee" />
        <PropertyColumn Title="Goalie Registration Fee" Property="x => x.GoalieRegistrationFee" />
        <ForeignColumn Title="Winner" Property="x => x.WinningTeam"
                       EqualityComparer="new TeamComparer()" ImageSrcFunc="t => t.Logo" />
    </Columns>
</EntityDataGrid>

@code {
    
    private readonly TournamentComparer _comparer = new();

    private async Task<Tournament?> NewItemFunc()
    {
        return new Tournament
        {
            Name = "New Tournament"
        };
    }
    
    private async Task UpdateTournamentLogo(ImageUploadResult<Tournament> result)
    {
        if (string.IsNullOrEmpty(result.NewKey)) 
            return;
        await TournamentService.UpdateLogoAsync(result.Item.Id, result.NewKey);
    }

}