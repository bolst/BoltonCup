@page "/tournaments/{TournamentId:int}/players"
@using System.Linq.Expressions
@inject IDialogService DialogService
@inject IDbContextFactory<BoltonCupDbContext> DbContextFactory
@{
#nullable enable
}

<EntityDataGrid
    @ref="_dataGrid"
    T="Player"
    SearchBy="x => x.Account.FirstName + ' ' + x.Account.LastName"
    Filter="@_filter"
    Comparer="_comparer">
    <ActionMenu>
        <MudMenuItem Label="Populate teams from draft" OnClick="@PopulateTeamsFromDraft" />
    </ActionMenu>
    <ToolbarContent>
        <MudSelect T="int?" Value="_selectedTeamId" ValueChanged="OnTeamFilterChanged" Label="Team"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense Clearable Class="mx-1" Style="min-width: 180px">
            <MudSelectItem T="int?" Value="@((int?)null)">All teams</MudSelectItem>
            @foreach (var team in _teams)
            {
                <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
            }
        </MudSelect>
    </ToolbarContent>
    <Columns>
        <PropertyColumn Title="Id" Property="x => x.Id" Editable="false"/>
        <ForeignColumn Title="Player" Property="x => x.Account" PropertySetter="(p, account) => p.Account = account!"
                       SearchBy="x => x.FirstName + ' ' + x.LastName" Editable="true" Required />
        <PropertyColumn Title="Account" Property="x => x.AccountId" Editable="false" />
        <PropertyColumn Title="Position" Property="x => x.Position" Required />
        <BoolColumn Title="Can play F/D" Property="x => x.CanPlayEitherPosition" />
        <PropertyColumn Title="Jersey Size" Property="x => x.JerseySize" />
        <PropertyColumn Title="Friends" Property="x => x.Friends" />
        <PropertyColumn Title="#" Property="x => x.JerseyNumber" Required="false" />
        <EnumColumn Title="Captaincy" Property="x => x.Captaincy" Required="false" />
        <ForeignColumn Title="Team" Property="x => x.Team" PropertySetter="(game, team) => { game.Team = team; game.TeamId = team?.Id; }"
                       EqualityComparer="new TeamComparer()!" ImageSrcFunc="x => x.Logo" Filter="_ => team => team.TournamentId == TournamentId"
                       Required="false" />
        <ForeignColumn Title="Tournament" Property="x => x.Tournament" Editable="false" ImageSrcFunc="x => x.Logo" />
    </Columns>
</EntityDataGrid>


@code {

    [Parameter]
    public int TournamentId { get; set; }

    private int? _tournamentId;

    private EntityDataGrid<Player>? _dataGrid;
    private static readonly PlayerComparer _comparer = new();

    private Expression<Func<Player, bool>>? _filter;

    private List<Team> _teams = [];
    private int? _selectedTeamId;

    protected override async Task OnParametersSetAsync()
    {
        if (_tournamentId == TournamentId)
            return;
        _tournamentId = TournamentId;
        _selectedTeamId = null;

        // Built once; EF re-reads the captured fields on each query execution, so
        // changing _selectedTeamId and reloading is enough to re-filter.
        _filter = x => x.TournamentId == _tournamentId
                       && (_selectedTeamId == null || x.TeamId == _selectedTeamId);

        await using var dbContext = await DbContextFactory.CreateDbContextAsync();
        _teams = await dbContext.Teams
            .AsNoTracking()
            .Where(t => t.TournamentId == _tournamentId)
            .OrderBy(t => t.Name)
            .ToListAsync();

        if (_dataGrid is not null)
        {
            await _dataGrid.ReloadAsync();
            StateHasChanged();
        }
    }

    private async Task OnTeamFilterChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        if (_dataGrid is not null)
        {
            await _dataGrid.ReloadAsync();
        }
    }

    private async Task PopulateTeamsFromDraft()
    {
        var dialog = await DialogService.ShowAsync<PopulateTeamsFromDraftDialog>(
            "Populate Teams From Draft",
            new DialogParameters<PopulateTeamsFromDraftDialog>
            {
                { x => x.TournamentId, TournamentId }
            });
        var result = await dialog.Result;

        if (result?.Data is true && _dataGrid is not null)
        {
            _selectedTeamId = null;
            await _dataGrid.ReloadAsync();
        }
    }

}
