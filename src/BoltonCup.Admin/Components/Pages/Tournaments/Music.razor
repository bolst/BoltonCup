@page "/tournaments/{TournamentId:int}/music"
@inject IMusicLibraryService MusicLibrary
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="4" Class="pa-4">
    <div class="d-flex align-center justify-space-between">
        <MudText Typo="Typo.h5">Music Library</MudText>
        <div class="d-flex align-center gap-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Rounded.PlaylistAdd"
                       OnClick="@ImportPlaylist">
                Import playlist
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Rounded.Add"
                       OnClick="@AddTrack">
                Add Track
            </MudButton>
        </div>
    </div>

    <MudTable Items="_tracks" Loading="_loading" Breakpoint="Breakpoint.Sm" Height="40vh" FixedHeader FixedFooter Hover Dense Virtualize>
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Artist</MudTh>
            <MudTh>Spotify tag</MudTh>
            <MudTh>Base pool</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Artist">@context.Artist</MudTd>
            <MudTd DataLabel="Track tag">
                @if (string.IsNullOrEmpty(context.TrackId))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">untagged</MudChip>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Rounded.Link" Color="Color.Success" Size="Size.Small" Title="@($"{context.ProviderType}: {context.TrackId}")" />
                }
            </MudTd>
            <MudTd DataLabel="Base pool">
                @if (context.IsInBasePool)
                {
                    <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
            </MudTd>
            <MudTd Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" OnClick="@(() => EditTrack(context))" />
                <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteTrack(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">No tracks uploaded yet.</MudText>
        </NoRecordsContent>
        <FooterContent>
            <MudTd colspan="5">
                <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Label="true">@_tracks.Count TOTAL</MudChip>
            </MudTd>
        </FooterContent>
    </MudTable>

    <MudExpansionPanels>
        <MudExpansionPanel Expanded="@(_pendingCount > 0)">
            <TitleContent>
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Rounded.CloudDownload" Color="@(_pendingCount > 0 ? Color.Warning : Color.Default)" />
                    <MudText>Download queue (@_pendingCount pending)</MudText>
                </div>
            </TitleContent>
            <ChildContent>
                <MudTable Items="_queue" Breakpoint="Breakpoint.Sm" Hover Dense>
                    <HeaderContent>
                        <MudTh>Song</MudTh>
                        <MudTh>Source</MudTh>
                        <MudTh>Base pool</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh Style="text-align:right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Song">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Square Size="Size.Small">
                                    @if (!string.IsNullOrEmpty(context.AlbumArtUrl))
                                    {
                                        <MudImage Src="@context.AlbumArtUrl" Alt="@context.Title" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Rounded.MusicNote" Size="Size.Small" />
                                    }
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body2">@(context.Title ?? context.TrackId)</MudText>
                                    @if (!string.IsNullOrEmpty(context.Artist))
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Artist</MudText>
                                    }
                                </div>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Source">
                            @if (context.Source == MusicTrackSource.PlaylistImport)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Import</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                                         Title="@($"Requested by {context.RequestedByName}")">Player</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Base pool">
                            @if (context.IsInBasePool)
                            {
                                <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            }
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@StatusColor(context.Status)">
                                @context.Status
                            </MudChip>
                        </MudTd>
                        <MudTd Style="text-align:right">
                            @if (context.Status != MusicTrackStatus.Cancelled)
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" Size="Size.Small"
                                               Title="Remove from queue" OnClick="@(() => CancelQueueItem(context))" />
                            }
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">The download queue is empty.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudStack>

@code {
    
    [Parameter]
    public int TournamentId { get; set; }

    private IReadOnlyList<TournamentMusicTrack> _tracks = [];
    private IReadOnlyList<MusicQueueItemView> _queue = [];
    private bool _loading = true;
    private int? _loadedId;

    private int _pendingCount => _queue.Count(q => q.Status == MusicTrackStatus.Pending);

    private static Color StatusColor(MusicTrackStatus status) => status switch
    {
        MusicTrackStatus.Downloaded => Color.Success,
        MusicTrackStatus.Pending => Color.Warning,
        _ => Color.Default,
    };

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == TournamentId)
            return;
        _loadedId = TournamentId;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _tracks = await MusicLibrary.GetLibraryAsync(TournamentId);
        _queue = await MusicLibrary.GetQueueAsync(TournamentId);
        _loading = false;
    }

    private async Task AddTrack()
    {
        var parameters = new DialogParameters { [nameof(MusicTrackDialog.TournamentId)] = TournamentId };
        var dialog = await DialogService.ShowAsync<MusicTrackDialog>("Add Track", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await ReloadAsync();
        }
    }

    private async Task EditTrack(TournamentMusicTrack track)
    {
        var parameters = new DialogParameters
        {
            [nameof(MusicTrackDialog.TournamentId)] = TournamentId,
            [nameof(MusicTrackDialog.Track)] = track,
        };
        var dialog = await DialogService.ShowAsync<MusicTrackDialog>("Edit Track", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await ReloadAsync();
        }
    }

    private async Task DeleteTrack(TournamentMusicTrack track)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Track",
            $"Delete \"{track.Title}\" from the library?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        try
        {
            await MusicLibrary.DeleteTrackAsync(TournamentId, track.Id);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ImportPlaylist()
    {
        var parameters = new DialogParameters { [nameof(ImportPlaylistDialog.TournamentId)] = TournamentId };
        var dialog = await DialogService.ShowAsync<ImportPlaylistDialog>("Import Spotify Playlist", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await ReloadAsync();
        }
    }

    private async Task CancelQueueItem(MusicQueueItemView item)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove from queue",
            $"Remove \"{item.Title ?? item.TrackId}\" from the download queue?",
            yesText: "Remove", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        try
        {
            await MusicLibrary.CancelQueueItemAsync(TournamentId, item.Id);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Remove failed: {ex.Message}", Severity.Error);
        }
    }
}
