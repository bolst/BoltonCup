@page "/tournaments/{TournamentId:int}/music"
@inject IMusicLibraryService MusicLibrary
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="4" Class="pa-4">
    <div class="d-flex align-center justify-space-between">
        <MudText Typo="Typo.h5">Music Library</MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Add"
                   OnClick="@AddTrack">
            Add Track
        </MudButton>
    </div>

    <MudTable Items="_tracks" Loading="_loading" Breakpoint="Breakpoint.Sm" Height="40vh" FixedHeader FixedFooter Hover Dense Virtualize>
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Artist</MudTh>
            <MudTh>Spotify tag</MudTh>
            <MudTh>Base pool</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Artist">@context.Artist</MudTd>
            <MudTd DataLabel="Track tag">
                @if (string.IsNullOrEmpty(context.TrackId))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">untagged</MudChip>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Rounded.Link" Color="Color.Success" Size="Size.Small" Title="@($"{context.ProviderType}: {context.TrackId}")" />
                }
            </MudTd>
            <MudTd DataLabel="Base pool">
                @if (context.IsInBasePool)
                {
                    <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
            </MudTd>
            <MudTd Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" OnClick="@(() => EditTrack(context))" />
                <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteTrack(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">No tracks uploaded yet.</MudText>
        </NoRecordsContent>
        <FooterContent>
            <MudTd colspan="5">
                <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Label="true">@_tracks.Count TOTAL</MudChip>
            </MudTd>
        </FooterContent>
    </MudTable>

    <MudExpansionPanels>
        <MudExpansionPanel>
            <TitleContent>
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Rounded.ReportProblem" Color="@(_missing.Count > 0 ? Color.Warning : Color.Default)" />
                    <MudText>Requested but missing (@_missing.Count)</MudText>
                </div>
            </TitleContent>
            <ChildContent>
                @if (_missing.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Every player song request has a matching uploaded file.</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                        These players requested songs with no matching uploaded file. Upload a track and tag it with the matching Spotify search result to fix.
                    </MudText>
                    <MudList T="string" ReadOnly Dense>
                        @foreach (var m in _missing)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Rounded.MusicOff">
                                <strong>@m.SongName</strong> — requested by @m.PlayerName
                            </MudListItem>
                        }
                    </MudList>
                }
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudStack>

@code {
    
    [Parameter]
    public int TournamentId { get; set; }

    private IReadOnlyList<TournamentMusicTrack> _tracks = [];
    private IReadOnlyList<MissingSongRequest> _missing = [];
    private bool _loading = true;
    private int? _loadedId;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId == TournamentId)
            return;
        _loadedId = TournamentId;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _tracks = await MusicLibrary.GetLibraryAsync(TournamentId);
        _missing = await MusicLibrary.GetMissingRequestsAsync(TournamentId);
        _loading = false;
    }

    private async Task AddTrack()
    {
        var parameters = new DialogParameters { [nameof(MusicTrackDialog.TournamentId)] = TournamentId };
        var dialog = await DialogService.ShowAsync<MusicTrackDialog>("Add Track", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await ReloadAsync();
        }
    }

    private async Task EditTrack(TournamentMusicTrack track)
    {
        var parameters = new DialogParameters
        {
            [nameof(MusicTrackDialog.TournamentId)] = TournamentId,
            [nameof(MusicTrackDialog.Track)] = track,
        };
        var dialog = await DialogService.ShowAsync<MusicTrackDialog>("Edit Track", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await ReloadAsync();
        }
    }

    private async Task DeleteTrack(TournamentMusicTrack track)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Track",
            $"Delete \"{track.Title}\" from the library?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        try
        {
            await MusicLibrary.DeleteTrackAsync(TournamentId, track.Id);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }
}
