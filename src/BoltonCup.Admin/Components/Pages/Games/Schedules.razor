@page "/games/schedules"
@inject IDialogService DialogService

<EntityDataGrid
    T="Game"
    @ref="@_dataGrid"
    NewItemFunc="NewItemFunc"
    Include="x => x.Include(p => p.Goals).Include(p => p.Penalties).Include(p => p.Referees)"
    Comparer="_comparer">
    <Columns>
        <ForeignColumn Title="Home" Property="x => x.HomeTeam" PropertySetter="(game, team) => game.HomeTeam = team" 
                       EqualityComparer="new TeamComparer()!" ImageSrcFunc="x => x.Logo"
                       Filter="@(x => (y => y.TournamentId == x.TournamentId))"/>
        <ForeignColumn Title="Away" Property="x => x.AwayTeam" PropertySetter="(game, team) => game.AwayTeam = team" 
                       EqualityComparer="new TeamComparer()!" ImageSrcFunc="x => x.Logo"
                       Filter="@(x => (y => y.TournamentId == x.TournamentId))"/>
        <DateTimePickerColumn Title="Date" Property="x => x.GameTime" />
        <EnumColumn Title="Type" Property="x => x.GameType"/>
        <EnumColumn Title="State" Property="x => x.GameState" />
        <PropertyColumn Title="Home placeholder" Property="x => x.HomeTeamPlaceholder"/>
        <PropertyColumn Title="Away placeholder" Property="x => x.AwayTeamPlaceholder"/>
        <PropertyColumn Title="Venue" Property="x => x.Venue"/>
        <PropertyColumn Title="Rink" Property="x => x.Rink"/>
        <ForeignColumn Title="Tournament" Property="x => x.Tournament" PropertySetter="(game, tournament) => game.Tournament = tournament!"
                       EqualityComparer="new TournamentComparer()!" ImageSrcFunc="t => t.Logo" />
        <TemplateColumn Title="Officials" Sortable="false" Editable="false">
            <CellTemplate>
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                           OnClick="@(() => EditReferees(context.Item))">
                    Edit (@context.Item.Referees.Count)
                </MudButton>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <ChildRowContent>
        @{
            var homeGoals = context.Item.Goals.Count(x => x.TeamId == context.Item.HomeTeamId);
            var awayGoals = context.Item.Goals.Count(x => x.TeamId == context.Item.AwayTeamId);
            var homePIMs = context.Item.Penalties.Where(x => x.TeamId == context.Item.HomeTeamId).Sum(x => x.DurationMinutes);
            var awayPIMs = context.Item.Penalties.Where(x => x.TeamId == context.Item.AwayTeamId).Sum(x => x.DurationMinutes);
        }
        <div class="pa-2 d-flex flex-row align-center gap-1">
            <MudChip T="string" Href='@($"/games/{context.Item.Id}/goals")' Text="@($"Goals ({homeGoals} - {awayGoals})")" Color="Color.Info" Variant="Variant.Text" Label="true"/>
            <MudChip T="string" Href='@($"/games/{context.Item.Id}/penalties")' Text="@($"Penalties ({homePIMs} - {awayPIMs})")" Color="Color.Info" Variant="Variant.Text" Label="true"/>
        </div>
    </ChildRowContent>
</EntityDataGrid>

@code {

    private EntityDataGrid<Game> _dataGrid = null!;
    private readonly GameComparer _comparer = new();
    
    private async Task<Game?> NewItemFunc()
    {
        return new Game
        {
            TournamentId = 1,
            GameTime = DateTime.Now,
        };
    }

    private async Task EditReferees(Game game)
    {
        var dialog = await DialogService.ShowAsync<AssignRefereesDialog>(
            "Assign officials",
            new DialogParameters<AssignRefereesDialog>
            {
                { x => x.GameId, game.Id },
                { x => x.GameLabel, game.ToString() },
            });

        var result = await dialog.Result;
        if (result?.Data is true)
        {
            await _dataGrid.ReloadAsync();
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await _dataGrid.ExtendSortAsync("Tournament.StartDate", SortDirection.Descending, x => x.Tournament.StartDate);
        await _dataGrid.ExtendSortAsync("GameTime", SortDirection.Ascending, x => x.GameTime);
    }
}