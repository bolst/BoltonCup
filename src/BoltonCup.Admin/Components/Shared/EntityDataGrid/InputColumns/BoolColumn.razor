@namespace BoltonCup.Admin.Components.Shared
@typeparam T where T : class
@inherits InputColumnBase<T, bool?>

@code {
    
    [Parameter]
    public bool TriState { get; set; }
    
    protected override RenderFragment EntityEditTemplate(CellContext<T> context)
    {
        var property = PropertyFunc(context.Item);
        if (property is not bool and not null)
        {
            return @<div></div>;
        }
        var item = property as bool?;
        if (!TriState)
            item ??= false;

        return @<MudCheckBox T="bool?" Value="@item" ValueChanged="t => SetProperty(context.Item, t)" Color="Color.Primary"
                             Class="rounded" TriState="TriState" Size="Size.Small" />;
    }
}