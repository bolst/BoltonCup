@namespace BoltonCup.Admin.Components.Shared
@typeparam T where T : class
@inherits InputColumnBase<T, string?>

@code {
    
    [Parameter]
    public EventCallback<ImageUploadResult<T>> OnImageUploaded { get; set; }

    private Task HandleImageUpload(T item, string? newKey)
        => OnImageUploaded.InvokeAsync(new ImageUploadResult<T>(item, newKey));
    
    protected override void OnInitialized()
    {
        base.OnInitialized();
        Sortable = false;
    }
    
    protected override RenderFragment EntityEditTemplate(CellContext<T> context)
    {
        var property = PropertyFunc(context.Item);
        if (property is not string and not null)
        {
            return @<div></div>;
        }

        var item = property as string;
        return @<div class="mud-width-full d-flex flex-column align-center justify-center">
                   <BoltonCupImage Src="@item" SrcChanged="t => HandleImageUpload(context.Item, t)" Height="24" Editable="Editable" />
               </div>;
    }
}