@namespace BoltonCup.Admin.Components.Shared
@typeparam T
@inherits ComponentBaseWithState

<CascadingValue Value="this" IsFixed="true">
    <MudDataGrid
        @ref="_dataGrid"
        T="T"
        ServerData="ServerFuncWrapper"
        CommittedItemChanges="OnItemEdited"
        Height="@GetHeight()"
        RowStyleFunc="RowStyleFunc"
        SelectedItems="@_selectedItemsState.Value"
        SelectedItemsChanged="@SetSelectedItemsAsync"
        ChildRowContent="@ChildRowContent"
        EditMode="DataGridEditMode.Cell"
        SortMode="SortMode.Multiple"
        Breakpoint="Breakpoint.None"
        ColumnResizeMode="@ColumnResizeMode"
        ReadOnly="@ReadOnly"
        Class="filter-datagrid"
        ShowColumnOptions="false"
        MultiSelection="Selectable"
        SelectOnRowClick="false"
        RowsPerPage="50"
        FixedHeader
        FixedFooter
        Hideable
        Bordered
        Dense>
        <ToolBarContent>
            <div class="mud-width-full d-flex flex-row align-center flex-wrap">
                <MudButtonGroup OverrideStyles="false" Size="Size.Small">
                    <MudTooltip Text="Delete Selected">
                        <MudIconButton OnClick="DeleteSelectedItems" Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" Disabled="@(Selection.Count == 0 || ReadOnly || NoDeleting)"/>
                    </MudTooltip>
                    @if (NewItemFunc is not null)
                    {
                        <MudTooltip Text="New Item">
                            <MudIconButton OnClick="AddNewItem" Icon="@Icons.Material.Rounded.Add" Color="Color.Primary" Disabled="ReadOnly"/>
                        </MudTooltip>
                    }
                    @if (ActionMenu is not null)
                    {
                        <MudMenu Icon="@Icons.Material.Rounded.KeyboardArrowDown">
                            @ActionMenu
                        </MudMenu>
                    }
                </MudButtonGroup>

                @if (ToolbarContent is not null)
                {
                    @ToolbarContent
                }

                <MudSpacer/>

                @if (SearchBy is not null)
                {
                    <MudTextField Class="mx-1" T="string" Value="_search" ValueChanged="SetSearchAsync" Label="Search" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.Search" AdornmentColor="Color.Info" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable/>
                }
                <MudButtonGroup OverrideStyles="false" Size="Size.Small">
                    <MudTooltip Text="Revert">
                        <MudIconButton OnClick="RevertChangesAsync" Icon="@Icons.Material.Rounded.Undo" Color="Color.Error" Disabled="!_changeTracker.IsDirty || ReadOnly"/>
                    </MudTooltip>
                    <MudTooltip Text="Save">
                        <MudIconButton OnClick="SaveChangesAsync" Icon="@Icons.Material.Rounded.Save" Color="Color.Primary" Disabled="!_changeTracker.IsDirty || ReadOnly"/>
                    </MudTooltip>
                </MudButtonGroup>
            </div>

        </ToolBarContent>
        <Columns>
            @if (ChildRowContent is not null)
            {
                <HierarchyColumn T="T" EnableHeaderToggle />
            }
            @if (Selectable)
            {
                <SelectColumn T="T" ShowInHeader/>
            }
            @Columns
        </Columns>
        <NoRecordsContent>
            <div class="d-flex justify-center align-center mud-width-full" style="height: 200px">
                <MudText Align="Align.Center">No records found</MudText>
            </div>
        </NoRecordsContent>
        <PagerContent>
            @if (!HidePagerContent)
            {
                <MudDataGridPager T="T" PageSizeOptions="_pageSizeOptions"/>
            }
        </PagerContent>
    </MudDataGrid>
</CascadingValue>
