@using MudBlazor.Utilities
@namespace BoltonCup.Admin.Components.Shared

<MudPaper Class="pa-4 d-flex flex-column align-start justify-space-between" Style="@Stylename">
    <MudText Typo="Typo.h4">@ChildContent</MudText>
    <MudText>@Title</MudText>
</MudPaper>


@code {

    [Parameter]
    public RenderFragment ChildContent { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Height { get; set; } = "130px";

    private string Stylename => new StyleBuilder()
        .AddStyle("height", Height)
        .Build();

}