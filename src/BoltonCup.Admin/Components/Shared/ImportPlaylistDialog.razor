@inject IMusicLibraryService MusicLibrary
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 420px;">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Paste a <strong>public</strong> Spotify playlist link. Its tracks are added to the download
                queue as base-pool songs (they play in every game once downloaded).
            </MudText>
            <MudTextField @bind-Value="_playlist"
                          Label="Spotify playlist URL or ID"
                          Placeholder="https://open.spotify.com/playlist/…"
                          Variant="Variant.Outlined"
                          Immediate
                          OnKeyDown="OnKeyDown" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_importing">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Import" Disabled="_importing">
            @(_importing ? "Importing…" : "Import")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance Dialog { get; set; } = null!;

    [Parameter]
    public int TournamentId { get; set; }

    private string _playlist = string.Empty;
    private bool _importing;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "NumpadEnter" && !_importing)
        {
            await Import();
        }
    }

    private async Task Import()
    {
        if (string.IsNullOrWhiteSpace(_playlist))
        {
            Snackbar.Add("Enter a playlist URL or ID.", Severity.Warning);
            return;
        }

        _importing = true;
        try
        {
            var count = await MusicLibrary.ImportPlaylistAsync(TournamentId, _playlist.Trim());
            Snackbar.Add(count == 0 ? "Nothing new to import." : $"Imported {count} song(s).", Severity.Success);
            Dialog.Close(DialogResult.Ok(count));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private void Cancel() => Dialog.Cancel();
}
