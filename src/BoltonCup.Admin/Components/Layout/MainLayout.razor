@using Microsoft.Extensions.Options
@inherits LayoutComponentBase
@inject Common.Theme.BoltonCupTheme Theme
@inject IOptions<Common.BoltonCupConfiguration> BcConfig
@inject NavigationManager Navigation

<MudThemeProvider Theme="Theme.MudTheme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudSpacer />
        
        <UserMenu>
            <LogOutTemplate>
                <form action="@($"{BcConfig.Value.ApiBaseUrl}api/auth/logout?returnUrl={Navigation.BaseUri}")" method="post">
                    <MudButton ButtonType="ButtonType.Submit" Color="Color.Error" FullWidth>Log Out</MudButton>
                </form>
            </LogOutTemplate>
        </UserMenu>
    </MudAppBar>
    <NavMenu @bind-Open="_isDrawerOpen" />
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>


@code {

    private bool _isDrawerOpen = true;

    private void ToggleDrawer() => _isDrawerOpen = !_isDrawerOpen;

}