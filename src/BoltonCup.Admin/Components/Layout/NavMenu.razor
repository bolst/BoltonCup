<MudDrawer Open="Open" OpenChanged="OpenChanged" Elevation="2">
    <MudDrawerHeader>
        <BoltonCupLogo Width="72" />
    </MudDrawerHeader>
    <MudNavMenu Class="px-2" Margin="Margin.Normal" Rounded>
        <MudNavLink Href="/" Icon="@Icons.Material.Rounded.Home" Match="NavLinkMatch.All">Home</MudNavLink>
        <MudNavLink Href="/registrations" Icon="@Icons.Material.Rounded.DynamicForm" Match="NavLinkMatch.All">Registrations</MudNavLink>
        <MudNavLink Href="/accounts" Icon="@Icons.Material.Rounded.ManageAccounts" Match="NavLinkMatch.Prefix">Accounts</MudNavLink>
        <MudNavLink Href="/tournaments" Icon="@Icons.Material.Rounded.Lan" Match="NavLinkMatch.All">Tournaments</MudNavLink>
        <MudNavLink Href="/teams" Icon="@Icons.Material.Rounded.Groups" Match="NavLinkMatch.Prefix">Teams</MudNavLink>
        <MudNavGroup Title="Games" Expanded>
            <MudNavLink Href="/games/schedules" Icon="@Icons.Material.Rounded.CalendarMonth" Match="NavLinkMatch.Prefix">Schedules</MudNavLink>
            <MudNavLink Href="/games/logs" Icon="@Icons.Material.Rounded.TableRows" Match="NavLinkMatch.Prefix">Logs</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="Authentication" Expanded>
            <MudNavLink Href="/authentication/users" Icon="@Icons.Material.Rounded.SupervisedUserCircle" Match="NavLinkMatch.Prefix">Users</MudNavLink>
            <MudNavLink Href="/authentication/roles" Icon="@Icons.Material.Rounded.AdminPanelSettings" Match="NavLinkMatch.Prefix">Roles</MudNavLink>
        </MudNavGroup>
    </MudNavMenu>
</MudDrawer>

@code {

    [Parameter]
    public bool Open { get; set; }
    
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

}