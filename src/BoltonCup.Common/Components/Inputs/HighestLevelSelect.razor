@using System.Linq.Expressions
@using BoltonCup.Core.Values
@namespace BoltonCup.Common.Components

<MudSelect 
    T="string?" 
    Value="@Value"
    ValueChanged="@ValueChanged" 
    For="@ValueExpression" 
    Label="@Label"
    Variant="@_variant"
    Disabled="@Disabled"
    OpenIcon="@OpenIcon" 
    Dense="@Dense"
    ShrinkLabel="@ShrinkLabel"
    Underline="@Underline" 
    Margin="@Margin" 
    Required="@Required"
    FullWidth="@FullWidth"
    OnlyValidateIfDirty="@OnlyValidateIfDirty"
    InputClass="disabled-select"
    Immediate
    >
    @foreach (var skillLevel in SkillLevel.All)
    {
        <MudSelectItem Value="@skillLevel" />
    }
</MudSelect>

<style>
    .disabled-select{
        color: var(--mud-palette-text-primary) !important;
    }
</style>

@code {

    [Parameter]
    public string? Value { get; set; }
    
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }
    
    [Parameter]
    public Expression<Func<string?>>? ValueExpression { get; set; }

    [Parameter]
    public string? Label { get; set; }
    
    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public Variant Variant { get; set; } = Variant.Outlined;

    [Parameter]
    public Margin Margin { get; set; } = Margin.Dense;

    [Parameter]
    public bool Underline { get; set; }

    [Parameter]
    public bool ShrinkLabel { get; set; } = true;

    [Parameter]
    public bool OnlyValidateIfDirty { get; set; }

    [Parameter]
    public bool FullWidth { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public bool Dense { get; set; } = true;

    private Variant _variant => Disabled ? Variant.Text : Variant;

    private string? OpenIcon => Disabled ? null : Icons.Material.Rounded.ArrowDropDown;

}