@using System.Linq.Expressions
@using BoltonCup.Core.Values
@namespace BoltonCup.Common.Components

<MudSelect 
    T="string?" 
    Value="@Value"
    ValueChanged="@ValueChanged" 
    For="@ValueExpression" 
    Label="@Label"
    Variant="@Variant"
    Disabled="@Disabled"
    ShrinkLabel="true"
    Margin="Margin.Dense" 
    Underline="false" 
    OpenIcon="@OpenIcon" 
    InputClass="disabled-select"
    Immediate
    Dense
    >
    @foreach (var skillLevel in SkillLevel.All)
    {
        <MudSelectItem Value="@skillLevel" />
    }
</MudSelect>

<style>
    .disabled-select{
        color: var(--mud-palette-text-primary) !important;
    }
</style>

@code {

    [Parameter]
    public string? Value { get; set; }
    
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }
    
    [Parameter]
    public Expression<Func<string?>>? ValueExpression { get; set; }

    [Parameter]
    public string? Label { get; set; }
    
    [Parameter]
    public bool Disabled { get; set; }

    private Variant Variant => Disabled ? Variant.Text : Variant.Outlined;

    private string? OpenIcon => Disabled ? null : Icons.Material.Rounded.ArrowDropDown;

}