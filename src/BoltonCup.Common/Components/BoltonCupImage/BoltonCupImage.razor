@namespace BoltonCup.Common.Components
@using MudBlazor.State
@using MudBlazor.Utilities
@inherits ComponentBaseWithState
@inject IDialogService DialogService
@inject Core.IAssetUrlResolver AssetUrlResolver

@if (!Editable)
{
    <MudImage Class="@Classname" Src="@AssetUrlResolver.GetFullUrl(_src)" Height="@Height" Width="@Width" ObjectFit="ObjectFit" />
}
else
{
    <div class="edit-image-container" @onclick="OnClick">
        <MudImage Class="@Classname" Src="@AssetUrlResolver.GetFullUrl(_src)" Height="@Height" Width="@Width" ObjectFit="ObjectFit" />
        <div class="@OverlayClassname">
            <MudIcon Icon="@Icons.Material.Filled.Edit" />
        </div>
    </div>
}


@code {
    
    [Parameter]
    public string? Src { get; set; }
    
    [Parameter]
    public EventCallback<string?> SrcChanged { get; set; }

    [Parameter]
    public int? Width { get; set; }

    [Parameter]
    public int? Height { get; set; }

    [Parameter]
    public RenderFragment ChildContent { get; set; } = null!;

    [Parameter]
    public bool Editable { get; set; }
    
    [Parameter]
    public bool ResolveUrl { get; set; } = true;
    
    [Parameter]
    public string? Class { get; set; }

    [Parameter] 
    public ObjectFit ObjectFit { get; set; } = ObjectFit.Fill;
    
    [Parameter]
    public bool Avatar { get; set; }

    private string? _src;
    
    private readonly ParameterState<string?> _srcState;

    private string Classname => new CssBuilder()
        .AddClass(Class)
        .AddClass("edit-image", Editable)
        .AddClass("rounded-circle", Avatar)
        .Build();

    private string OverlayClassname => new CssBuilder()
        .AddClass("overlay-container")
        .AddClass("rounded-circle", Avatar)
        .Build();
    

    public BoltonCupImage()
    {
        using var registerScope = CreateRegisterScope();
        _srcState = registerScope.RegisterParameter<string?>(nameof(Src))
            .WithParameter(() => Src)
            .WithEventCallback(() => SrcChanged)
            .WithChangeHandler(OnSrcChange);
    }

    private void OnSrcChange(ParameterChangedEventArgs<string?> args)
    {
        _src = args.Value;
        StateHasChanged();
    }

    private async Task OnClick()
    {
        var dialog = await DialogService.ShowAsync<EditImageDialog>("Edit Image", new DialogParameters<EditImageDialog>
        {
            { x => x.Src, _src },
        });
        var result = await dialog.Result;
        if (result?.Data is string newSrc)
        {
            await _srcState.SetValueAsync(newSrc);
        }
    }
    
}