@namespace BoltonCup.Common.Components
@inject IOptions<BoltonCupConfiguration> BcConfig

<footer class="mud-appbar" style="z-index: 1000 !important">
    <MudContainer Class="py-6 d-flex flex-column align-center gap-3">
        <FooterSection>
            <MudIconButton Icon="@Icons.Custom.Brands.Instagram" Href="https://instagram.com/bolton_cup" Class="rounded-circle" Color="Color.Inherit" Variant="Variant.Outlined" Size="Size.Small"/>
        </FooterSection>
        
        <FooterSection>
            <MudLink Color="Color.Inherit" Href="@($"{BcConfig.Value.WebBaseUrl}contact")">Contact</MudLink>
            <MudLink Color="Color.Inherit" Href="@($"{BcConfig.Value.WebBaseUrl}privacy-policy")">Privacy Policy</MudLink>
        </FooterSection>
        
        <MudDivider Style="border-color: #868686 !important;" />
        
        <FooterSection>
            <BoltonCupLogo Width="48" />
        </FooterSection>
    </MudContainer>
</footer>


