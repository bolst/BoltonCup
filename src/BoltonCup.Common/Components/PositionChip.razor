@namespace BoltonCup.Common.Components

@if (_positionStyle is not null)
{
    @if (CanPlayBoth)
    {
        <MudTooltip Text="Can play both forward and defense" Arrow Placement="Placement.Top">
            <MudBadge Content="@_fdBadge" Color="Color.Info" Overlap="true">
                @PositionChipFragment
            </MudBadge>
        </MudTooltip>
    }
    else
    {
        @PositionChipFragment
    }
}

@code {

    private const string _fdBadge = "F/D";

    [Parameter]
    [EditorRequired]
    public string Position { get; set; }

    [Parameter]
    public Size Size { get; set; } = Size.Medium;

    [Parameter]
    public Variant Variant { get; set; } = Variant.Text;

    [Parameter]
    public bool Abbreviated { get; set; }

    /// <summary>When true, renders an "F/D" badge indicating the player can play both forward and defense.</summary>
    [Parameter]
    public bool CanPlayBoth { get; set; }

    private PositionStyle? _positionStyle;

    private RenderFragment PositionChipFragment => @<MudChip
                                                        T="string"
                                                        Color="@_positionStyle!.Color"
                                                        Size="@Size"
                                                        Variant="@Variant"
                                                        Label="true">
                                                       @(Abbreviated ? _positionStyle.Position[..1] : _positionStyle.Position)
                                                   </MudChip>;

    protected override void OnParametersSet()
    {
        if (_positionStyle?.Position == Position)
            return;
        _positionStyle = new PositionStyle(Position);
    }

    public class PositionStyle
    {
        public string Position { get; }
        public Color Color { get; }

        public PositionStyle(string position)
        {
            Position = position.ToUpper();

            Color = position switch
            {
                Core.Values.Position.Forward => Color.Primary,
                Core.Values.Position.Defense => Color.Secondary,
                Core.Values.Position.Goalie => Color.Success,
                _ => Color
            };
        }
    }

}
