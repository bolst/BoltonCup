@namespace BoltonCup.Common.Components
@using MudBlazor.State
@inherits FilterFieldBase<IReadOnlyCollection<Sdk.TeamDto?>>
@inject IBoltonCupApi BoltonCupApi

<MudSelect
    T="Sdk.TeamDto?"
    SelectedValues="@ContextValue"
    SelectedValuesChanged="@ContextValueChanged"
    OpenChanged="OnOpenChange"
    Disabled="@Disabled"
    ToStringFunc="x => x?.NameShort"
    Label="Team"
    Typo="Typo.subtitle2"
    Variant="Variant.Outlined"
    Margin="Margin.Dense"
    MultiSelection
    Dense>
    @foreach (var option in _options ?? [])
    {
        <MudSelectItem Value="@option">@option.Name</MudSelectItem>
    }
</MudSelect>

@code {
    
    [Parameter]
    public int? TournamentId { get; set; }

    private ICollection<Sdk.TeamDto>? _options;

    public TeamFilter()
    {
        using var registerScope = CreateRegisterScope();
        registerScope.RegisterParameter<int?>(nameof(TournamentId))
            .WithParameter(() => TournamentId)
            .WithChangeHandler(OnTournamentIdChange);
    }

    private Task OnTournamentIdChange(ParameterChangedEventArgs<int?> args)
    {
        Console.WriteLine($"tournament id changed: {args.Value}");
        return ContextValueChanged.InvokeAsync(null);
    }

    private async Task OnOpenChange(bool open)
    {
        if (open && _options is null && TournamentId.HasValue)
        {
            var result = await BoltonCupApi.GetTeamsAsync();
            _options = result.Items.Where(x => x.Tournament.Id == TournamentId.Value).ToList();
        }
    }
}