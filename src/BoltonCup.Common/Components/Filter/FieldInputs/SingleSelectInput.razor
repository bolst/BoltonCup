@namespace BoltonCup.Common.Components
@inherits FieldInputBase


<MudSelect 
    T="Sdk.FilterOptionDto"
    Value="@_selectedOption" 
    ValueChanged="@OnSelectedOptionChanged"
    Typo="Typo.subtitle2"
    Variant="Variant.Outlined" 
    Margin="Margin.Dense" 
    FitContent
    Dense 
    >
    @foreach (var option in Options)
    {
        <MudSelectItem T="Sdk.FilterOptionDto" Value="option">@option.Label</MudSelectItem>
    }
</MudSelect>


@code {

    private Sdk.FilterOptionDto? _selectedOption;
    
    protected override Task OnValueChangedAsync(FilterValue? value)
    {
        _selectedOption = value?.Value;
        return base.OnValueChangedAsync(value);
    }

    private Task OnSelectedOptionChanged(Sdk.FilterOptionDto? option)
    {
        var value = new FilterValue { Value = option };
        return SetValueAsync(value);
    }
    
}