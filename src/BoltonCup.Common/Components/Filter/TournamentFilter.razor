@namespace BoltonCup.Common.Components
@inherits FilterFieldBase<Sdk.TournamentDto>
@inject IBoltonCupApi BoltonCupApi

<MudAutocomplete
    Value="@ContextValue"
    ValueChanged="@ContextValueChanged"
    SearchFunc="@SearchFunc"
    ToStringFunc="x => x?.Name"
    Label="Tournament"
    Typo="Typo.subtitle2"
    Variant="Variant.Outlined"
    Margin="Margin.Dense"
    Strict="false"
    Dense />

@code {

    private ICollection<Sdk.TournamentDto>? _options;
    
    private async Task<IEnumerable<Sdk.TournamentDto>> SearchFunc(string? search, CancellationToken cancellationToken)
    {
        if (_options is null)
        {
            var result = await BoltonCupApi.GetTournamentsAsync(cancellationToken: cancellationToken);
            _options = result.Items;
        }

        if (string.IsNullOrEmpty(search))
            return _options;

        return _options.Where(x => x.Name.Contains(search, StringComparison.OrdinalIgnoreCase));

    }
    
}