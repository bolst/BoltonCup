@using BoltonCup.Draft.Services
@namespace BoltonCup.Draft.Components
@implements IDisposable
@inject DraftStateService DraftState

@if (DraftState.Draft is not null)
{
    <MudTable
        T="Sdk.TeamDraftPicks"
        Items="@(DraftState.Draft.DraftPicks)"
        Elevation="0">
        <HeaderContent>
        </HeaderContent>
        <RowTemplate>
            @foreach (var pick in context.Picks)
            {
                <MudTd>
                    <MudPaper Height="24px" Width="48px" Elevation="1">
                        @pick.OverallPick @pick.Player?.FullName
                    </MudPaper>
                </MudTd>
            }
        </RowTemplate>
    </MudTable>
}


@code {

    protected override void OnInitialized()
    {
        DraftState.OnStateChanged += StateHasChanged;
    }


    public void Dispose()
    {
        DraftState.OnStateChanged -= StateHasChanged;
    }
}