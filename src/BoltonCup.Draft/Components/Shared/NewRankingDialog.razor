@namespace BoltonCup.Draft.Components.Shared
@using System.ComponentModel.DataAnnotations
@using BoltonCup.Common
@implements IDisposable
@inject IBoltonCupApi BoltonCupApi
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <div class="mud-width-full my-2">
            <MudText Typo="Typo.h6">Create a new ranking</MudText>
        </div>

        @if (_editContext is not null)
        {
            <EditForm EditContext="_editContext" OnValidSubmit="@CreateRankingAsync" class="mud-width-full">
                <DataAnnotationsValidator/>
                <MudStack Spacing="6">
                    <MudTextField
                        @bind-Value="@_model.Title"
                        For="@(() => _model.Title)"
                        Label="Title"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Required/>

                    <MudSelect
                        @bind-Value="@_model.Tournament"
                        For="@(() => _model.Tournament)"
                        Label="Tournament"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Dense
                        Required>
                        @foreach (var tournament in _tournamentOptions)
                        {
                            <MudSelectItem Value="@tournament">@tournament.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <div class="d-flex flex-row align-center justify-end gap-1">
                        <MudButton OnClick="@Dialog.Cancel">Cancel</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Create Ranking</MudButton>
                    </div>
                </MudStack>
            </EditForm>
        }
    </DialogContent>
</MudDialog>


@code {

    [CascadingParameter]
    public IMudDialogInstance Dialog { get; set; } = null!;

    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;
    private readonly CreateRankingFormModel _model = new();

    private ICollection<Sdk.TournamentDto> _tournamentOptions = [];

    protected override async Task OnInitializedAsync()
    {
        await Dialog.SetOptionsAsync(Dialog.Options with
        {
            CloseOnEscapeKey = false,
            BackdropClick = true,
            NoHeader = true,
            CloseButton = false,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
        });

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var response = await BoltonCupApi.GetTournamentsAsync();
        var allTournaments = response.Items;

        // GMs only see the tournaments they manage; admins see all
        _tournamentOptions = user.IsInRole("Admin")
            ? allTournaments
            : allTournaments.Where(t => user.IsGmForTournament(t.Id)).ToList();

        _editContext = new EditContext(_model);
        _messageStore = new ValidationMessageStore(_editContext);
    }

    private async Task CreateRankingAsync()
    {
        try
        {
            var rankingId = await BoltonCupApi.CreateCustomRankingAsync(new Sdk.CreateCustomRankingRequest
            {
                Title = _model.Title ?? "New Ranking",
                TournamentId = _model.Tournament!.Id
            });
            Dialog.Close(DialogResult.Ok(rankingId));
        }
        catch (Sdk.ApiException<Sdk.BoltonCupValidationProblemDetails> e)
        {
            _messageStore?.AddApiErrorResponse(_model, e.Result);
            _editContext?.NotifyValidationStateChanged();
        }
    }

    public void Dispose()
    {
    }


    private sealed class CreateRankingFormModel
    {
        [Required(ErrorMessage = "Please name the ranking.")]
        public string? Title { get; set; }

        [Required(ErrorMessage = "Please select a tournament.")]
        public Sdk.TournamentDto? Tournament { get; set; }
    }

}
