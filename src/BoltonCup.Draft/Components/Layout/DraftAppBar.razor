@using BoltonCup.Draft.Services
@implements IDisposable
@inject DraftStateService DraftState

<MudAppBar Elevation="1" ToolBarClass="d-flex flex-row align-center justify-space-between">
    <MudButtonGroup OverrideStyles="false">
        <MudIconButton
            Href="/" Icon="@Icons.Material.Rounded.KeyboardArrowLeft" Class="rounded"/>
    </MudButtonGroup>

    <MudHidden Breakpoint="Breakpoint.MdAndUp" Invert>

        @switch (DraftState.Draft?.Status)
        {
            case Sdk.DraftStatus.Pending:
                <AuthorizeView Roles="Admin">
                    <MudButton OnClick="@StartDraftAsync" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large">Start Draft</MudButton>
                </AuthorizeView>
                break;
            case Sdk.DraftStatus.InProgress when DraftState.CurrentPick is {} currentPick:
                <div class="d-flex flex-row align-center gap-1">
                    <MudText Typo="Typo.h6">Pick @currentPick.OverallPick</MudText>
                    <MudImage Src="@currentPick.Team.Logo" Height="48" />
                </div>
                break;
        }

        <MudButtonGroup OverrideStyles="false">
            <MudIconButton Icon="@Icons.Material.Filled.Settings" OnClick="@OpenSettingsAsync"/>
        </MudButtonGroup>
    </MudHidden>


    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudSpacer/>
        <MudIconButton OnClick="@OpenDrawer" Icon="@Icons.Material.Rounded.Menu" Variant="Variant.Text" Color="Color.Inherit"/>
        <MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="1" Variant="DrawerVariant.Temporary" Width="100%">
            <MudPaper Class="d-flex flex-row align-center px-2 border-solid border-b" Elevation="0" Width="100%" Height="64px" Square>
                <a href="/" onclick="location.reload()" style="height: 100%">
                    <BoltonCupLogo Height="64"/>
                </a>
                <MudSpacer/>
                <MudIconButton OnClick="@CloseDrawer" Icon="@Icons.Material.Rounded.Close" Variant="Variant.Text" Color="Color.Inherit"/>
            </MudPaper>

            <MudNavMenu Class="mud-width-full" Color="Color.Primary" Margin="Margin.Normal" Rounded Bordered>

            </MudNavMenu>
        </MudDrawer>
    </MudHidden>
</MudAppBar>

@code {

    private bool _drawerOpen;

    private void OpenDrawer() => _drawerOpen = true;
    private void CloseDrawer() => _drawerOpen = false;

    protected override void OnInitialized()
    {
        DraftState.OnStateChanged += StateHasChanged;
    }

    private async Task StartDraftAsync()
    {
        
    }
    
    private async Task OpenSettingsAsync()
    {
        
    }

    public void Dispose()
    {
        DraftState.OnStateChanged -= StateHasChanged;
    }

}