@page "/drafts/{DraftId:int}"
@using BoltonCup.Draft.Services
@layout Layout.DraftLayout
@implements IAsyncDisposable
@inject DraftStateService DraftState

@if (_loading)
{
    
}
else if (DraftState.Draft is not null)
{
    <MudSplitPanel 
        Class="mud-width-full" Style="height: calc(100vh - 64px)"  
        FirstPanelInitialSize="300" MinPanelSize="50" Horizontal Transparent>
        <FirstPanel>
            <div class="mud-height-full overflow-y-auto overflow-x-hidden">
                <DraftDataGrid/>
            </div>
        </FirstPanel>
        <SecondPanel>
            <div class="mud-height-full overflow-y-auto overflow-x-hidden">
                <DraftToolDrawer/>
            </div>
        </SecondPanel>
    </MudSplitPanel>
}

@code {
    
    [Parameter]
    [EditorRequired]
    public required int DraftId { get; set; }

    private int? _draftId;

    private bool _loading;
    
    protected override async Task OnParametersSetAsync()
    {
        if (DraftId == _draftId)
            return;
        _draftId = DraftId;

        _loading = true;

        await DraftState.InitializeAsync(DraftId);

        _loading = false;
        await InvokeAsync(StateHasChanged);
    }
    

    public async ValueTask DisposeAsync()
    {
    }
}