@page "/drafts/{DraftId:int}/manager"
@attribute [Authorize(Roles = "Admin")]
@inject IBoltonCupApi BoltonCupApi

<MudDrawer 
    Open="@_drawerOpen" OpenChanged="@SetDrawerOpen" Elevation="1"
    Anchor="Anchor.Right" Variant="DrawerVariant.Mini" Breakpoint="Breakpoint.None"
    Width="350px" Height="calc(100vh - 64px)" Fixed="false" OpenMiniOnHover="false">
    @if (_selectedPlayer is not null)
    {
        <MudDrawerHeader>
            <MudStack Class="mud-width-full" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Row>
                <MudText Typo="Typo.h6">@_selectedPlayer.Player.FullName</MudText>
                <MudIconButton OnClick="@(() => SetDrawerOpen(false))" Icon="@Icons.Material.Rounded.Close" Class="rounded" Size="Size.Small" />
            </MudStack>
        </MudDrawerHeader>
        
        <MudStack Class="pa-1 mud-height-full">
            <MudImage Src="@_selectedPlayer.Player.ProfilePicture" Width="150" />
            
            <MudSpacer />
            
            <MudButton OnClick="@DraftSelectedPlayer" Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" FullWidth>Draft @_selectedPlayer.Player.FullName</MudButton>
        </MudStack>
    }
</MudDrawer>

@if (_draft is not null)
{
    <MudDataGrid
        @ref="_dataGrid"
        T="Sdk.DraftRankingDto"
        Class="filter-datagrid"
        ServerData="@PlayerServerFunc"
        RowClick="@(x => OpenPlayerDrawer(x.Item))"
        Breakpoint="Breakpoint.None"
        RowClass="cursor-pointer"
        RowStyle="height: 50px"
        RowsPerPage="50"
        Elevation="0"
        ShowColumnOptions="false"
        Height="75vh"
        Hover
        FixedHeader
        FixedFooter
        AllowUnsorted
        Striped
        Dense>
        <ToolBarContent>
            <div class="d-flex flex-row align-center gap-3 flex-wrap">
                <FilterToolbarField
                    T="string?" Label="Position"
                    @bind-Value="@_filter.Position" OnApplyClicked="@_dataGrid.ReloadServerData">
                    <PositionFilter/>
                </FilterToolbarField>
            </div>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Title="Player" Property="x => x.Player.FullName">
                <CellTemplate>
                    <MudText Typo="Typo.body2"><b>@context.Item.Player.FullName</b></MudText>
                </CellTemplate>
                <FooterTemplate>
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text" Label="true">@context.Items.Count(x => x.Player.Position == Core.Values.Position.Forward) forwards</MudChip>
                </FooterTemplate>
            </PropertyColumn>
            <PropertyColumn Title="Position" Property="x => x.Player.Position">
                <FooterTemplate>
                    <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Variant="Variant.Text" Label="true">@context.Items.Count(x => x.Player.Position == Core.Values.Position.Defense) defensemen</MudChip>
                </FooterTemplate>
            </PropertyColumn>
            <PropertyColumn Title="PPG" Property="x => x.DraftRanking" Format="F3" />
            <PropertyColumn Title="P" Property="x => x.TotalPoints" />
            <PropertyColumn Title="GP" Property="x => x.GamesPlayed" />
            <PropertyColumn Title="Year" Property="x => x.Player.Birthday" Format="yyyy">
                <FooterTemplate>
                    <MudChip T="string" Color="Color.Dark" Size="Size.Small" Variant="Variant.Text" Label="true">@context.Items.Count(x => x.Player.IsGoalie) goalies</MudChip>
                </FooterTemplate>
            </PropertyColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Sdk.DraftRankingDto" PageSizeSelector="false"/>
        </PagerContent>
    </MudDataGrid>
}
else
{
    <MudAlert Severity="Severity.Error">No draft found.</MudAlert>
}


@code {

    [Parameter]
    [EditorRequired]
    public required int DraftId { get; set; }

    private int? _draftId;

    private Sdk.DraftSingleDto? _draft;

    private bool _drawerOpen;
    private Sdk.DraftRankingDto? _selectedPlayer;

    private readonly DraftManagerFilterModel _filter = new();
    private MudDataGrid<Sdk.DraftRankingDto> _dataGrid = null!;

    private bool _sorted;

    protected override async Task OnParametersSetAsync()
    {
        if (_draftId == DraftId)
            return;
        _draftId = DraftId;

        _draft = await BoltonCupApi.GetDraftByIdAsync(DraftId);
    }

    private async Task<GridData<Sdk.DraftRankingDto>> PlayerServerFunc(GridState<Sdk.DraftRankingDto> state, CancellationToken cancellationToken)
    {
        if (_draft is null)
        {
            return new GridData<Sdk.DraftRankingDto>
            {
                TotalItems = 0,
                Items = []
            };
        }
        
        string? sortBy = null;
        bool? descending = null;
        var sortDefinition = state.SortDefinitions.FirstOrDefault();
        if (sortDefinition is not null)
        {
            sortBy = sortDefinition.SortBy;
            descending = sortDefinition.Descending;
        }
        else
        {
            sortBy = "DraftRanking";
            descending = true;
        }
        

        var data = await BoltonCupApi.GetDraftRankingsAsync(
            id: _draft.Id, 
            page: state.Page + 1, 
            size: state.PageSize,
            sortBy: sortBy,
            descending: descending, 
            cancellationToken: cancellationToken
        );
        
        return new GridData<Sdk.DraftRankingDto>
        {
            TotalItems = data.Total,
            Items = data.Items,
        };
    }

    private Task SetDrawerOpen(bool open)
    {
        if (open && _selectedPlayer is null)
            return Task.CompletedTask;
        if (!open)
            _selectedPlayer = null;
        
        _drawerOpen = open;
        return InvokeAsync(StateHasChanged);
    }

    private void OpenPlayerDrawer(Sdk.DraftRankingDto player)
    {
        _selectedPlayer = player;
        _drawerOpen = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task DraftSelectedPlayer()
    {
        if (_selectedPlayer is null)
            return;
        // await BoltonCupApi.DraftPlayerAsync(DraftId, new Sdk.DraftPlayerRequest
        // {
        //     PlayerId = _selectedPlayer.Id,
        //     TeamId = _currentPick.Team.Id,
        //     OverallPick = _currentPick.OverallPick
        // });
    }
    
    private class DraftManagerFilterModel
    {
        public string? Position { get; set; }
    }
}