@page "/"
@using BoltonCup.Sdk
@inject IBoltonCupApi BoltonCupApi
@inject NavigationManager Navigation
@inject IDialogService DialogService


<PageTitle>Drafts</PageTitle>

<MudContainer Class="py-2" MaxWidth="MaxWidth.Medium">
    <div class="mud-width-full d-flex align-center justify-center py-2 gap-3">
        <MudToggleGroup
            T="bool" Value="@_showInProgress" ValueChanged="@SetShowInProgress" Color="Color.Primary">
            <MudToggleItem T="bool" Value="true">In Progress</MudToggleItem>
            <MudToggleItem T="bool" Value="false">Completed</MudToggleItem>
        </MudToggleGroup>
        
        <AuthorizeView Roles="Admin">
            <MudButton OnClick="@CreateNewDraftAsync" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add">New</MudButton>
        </AuthorizeView>
    </div>
    
    <MudStack Class="mud-width-full" AlignItems="AlignItems.Center">
        @foreach (var draft in _drafts)
        {
            <MudPaper Class="pa-4 d-flex flex-column align-center justify-space-between cursor-pointer" 
                      @onclick="@(_ => NavigateToDraft(draft.Id))" Width="100%" Height="150px" Elevation="0" Square Outlined>
                <div class="mud-width-full d-flex flex-row align-center justify-space-between">
                    <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Label="true">@draft.Status.ToString()</MudChip>
                    <MudText Typo="Typo.caption">@DateTime.Now.ToString("g")</MudText>
                </div>
                <div class="d-flex flex-row align-center gap-1">
                    <MudText Typo="Typo.h6">@draft.Tournament.Name</MudText>
                    <MudImage Src="@draft.Tournament.Logo" Height="32"/>
                </div>
                <div class="mud-width-full d-flex flex-row align-center justify-space-evenly flex-grow-1">
                    @ValueLabel("15", "Rounds")
                    <MudDivider FlexItem Vertical/>
                    @ValueLabel("4", "Teams")
                    <MudDivider FlexItem Vertical/>
                    @ValueLabel("2 Min", "Timer")
                </div>
            </MudPaper>
        }
    </MudStack>
</MudContainer>


@code {

    private bool _showInProgress = true;
    private ICollection<Sdk.DraftDto>? _draftsSource;
    private ICollection<Sdk.DraftDto> _drafts = [];

    protected override Task OnInitializedAsync()
    {
        return LoadDraftsAsync();
    }

    private async Task LoadDraftsAsync()
    {
        _draftsSource ??= (await BoltonCupApi.GetDraftsAsync()).Items;
        _drafts = _draftsSource.Where(
                d => _showInProgress 
                ? d.Status != DraftStatus.Completed
                : d.Status == DraftStatus.Completed
            )
            .ToList();
        await InvokeAsync(StateHasChanged);
    }

    private Task SetShowInProgress(bool showInProgress)
    {
        _showInProgress = showInProgress;
        return LoadDraftsAsync();
    }

    private void NavigateToDraft(int draftId)
    {
        Navigation.NavigateTo($"/drafts/{draftId}");
    }
    
    private async Task CreateNewDraftAsync()
    {
        var dialog = await DialogService.ShowAsync<NewDraftDialog>();
        var result = await dialog.Result;
        if (result?.Data is int newDraftId)
        {
            Navigation.NavigateTo($"/drafts/{newDraftId}/config");
        }
    }

    private RenderFragment ValueLabel(string value, string label)
    {
        return @<div>
                   <MudText Typo="Typo.subtitle1" Align="Align.Center">@value</MudText>
                   <MudText Typo="Typo.caption" Align="Align.Center">@label</MudText>
               </div>;
    }
}