@page "/rankings"
@attribute [Authorize]
@using BoltonCup.Sdk
@inject IBoltonCupApi BoltonCupApi
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider


<PageTitle>Player Rankings</PageTitle>

<MudContainer Class="py-2" MaxWidth="MaxWidth.Medium">
    <MudText Typo="Typo.h5" Class="py-2">Player Rankings</MudText>

    <MudTabs Rounded ApplyEffectsToContainer>
        <MudTabPanel Text="@($"My Rankings ({_rankings.Count})")">
            <div class="mud-width-full d-flex justify-end pb-2">
                <MudButton OnClick="@CreateNewRankingAsync" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add">New</MudButton>
            </div>
            @if (_rankings.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="my-4">You haven't created any rankings yet.</MudAlert>
            }
            else
            {
                <MudStack Class="mud-width-full" AlignItems="AlignItems.Center">
                    @foreach (var ranking in _rankings)
                    {
                        @RankingRow(ranking, owned: true)
                    }
                </MudStack>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Shared with me ({_shared.Count})")">
            @if (_shared.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="my-4">No rankings have been shared with you.</MudAlert>
            }
            else
            {
                <MudStack Class="mud-width-full" AlignItems="AlignItems.Center">
                    @foreach (var ranking in _shared)
                    {
                        @RankingRow(ranking, owned: false)
                    }
                </MudStack>
            }
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private RenderFragment RankingRow(Sdk.CustomRankingDto ranking, bool owned) =>
        @<MudPaper Class="pa-4 d-flex flex-row align-center justify-space-between cursor-pointer"
                   @onclick="@(_ => NavigateToRanking(ranking.Id))" Width="100%" Elevation="0" Square Outlined>
            <div class="d-flex flex-row align-center gap-3">
                <MudImage Src="@ranking.Tournament.Logo" Height="32"/>
                <div>
                    <MudText Typo="Typo.h6">@ranking.Title</MudText>
                    <MudText Typo="Typo.caption">
                        @ranking.Tournament.Name · @ranking.PlayerCount players@(owned ? string.Empty : $" · Created by {ranking.CreatedByName}")
                    </MudText>
                </div>
            </div>
            <div @onclick:stopPropagation="true" class="d-flex flex-row align-center">
                <MudIconButton Icon="@Icons.Material.Rounded.ContentCopy" Color="Color.Default"
                               OnClick="@(() => CloneRankingAsync(ranking))"/>
                @if (owned)
                {
                    <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error"
                                   OnClick="@(() => DeleteRankingAsync(ranking.Id))"/>
                }
            </div>
        </MudPaper>;
}


@code {

    private ICollection<Sdk.CustomRankingDto> _rankings = [];
    private ICollection<Sdk.CustomRankingDto> _shared = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (!user.IsInRole("Admin") && !user.GetTournamentGmIds().Any())
        {
            Navigation.NavigateTo("/");
            return;
        }

        await LoadRankingsAsync();
    }

    private async Task LoadRankingsAsync()
    {
        _rankings = await BoltonCupApi.GetCustomRankingsAsync();
        _shared = await BoltonCupApi.GetSharedCustomRankingsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void NavigateToRanking(int id)
    {
        Navigation.NavigateTo($"/rankings/{id}");
    }

    private async Task CreateNewRankingAsync()
    {
        var dialog = await DialogService.ShowAsync<NewRankingDialog>();
        var result = await dialog.Result;
        if (result?.Data is int newId)
        {
            NavigateToRanking(newId);
        }
    }

    private async Task CloneRankingAsync(Sdk.CustomRankingDto ranking)
    {
        var parameters = new DialogParameters<CloneRankingDialog> { { x => x.SourceTitle, ranking.Title } };
        var dialog = await DialogService.ShowAsync<CloneRankingDialog>("Make a copy", parameters);
        var result = await dialog.Result;
        if (result?.Data is not string title)
            return;

        var newId = await BoltonCupApi.CloneCustomRankingAsync(ranking.Id, new Sdk.CloneCustomRankingRequest { Title = title });
        NavigateToRanking(newId);
    }

    private async Task DeleteRankingAsync(int id)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete ranking",
            "Are you sure you want to delete this ranking?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true)
            return;

        await BoltonCupApi.DeleteCustomRankingAsync(id);
        await LoadRankingsAsync();
    }
}
