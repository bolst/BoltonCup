@page "/rankings/{Id:int}"
@attribute [Authorize]
@using BoltonCup.Sdk
@using BoltonCup.Draft.Services
@using Position = BoltonCup.Core.Values.Position
@inject IBoltonCupApi BoltonCupApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<PageTitle>@(_ranking?.Title ?? "Ranking")</PageTitle>

<MudContainer Class="py-2" MaxWidth="@(_viewMode == ViewMode.Grid ? MaxWidth.ExtraLarge : MaxWidth.Medium)">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary"/>
    }
    else if (_ranking is null)
    {
        <MudAlert Severity="Severity.Error">Ranking not found.</MudAlert>
    }
    else
    {
        <div class="mud-width-full d-flex align-center justify-space-between py-2 gap-3 flex-wrap">
            <div class="d-flex flex-row align-center gap-3">
                <MudIconButton Icon="@Icons.Material.Rounded.ArrowBack" OnClick="@(() => Navigation.NavigateTo("/rankings"))"/>
                <MudImage Src="@_ranking.Tournament.Logo" Height="32"/>
                <div>
                    <MudText Typo="Typo.h6">@_ranking.Title</MudText>
                    <MudText Typo="Typo.caption">@_ranking.Tournament.Name@(_ranking.CanEdit ? string.Empty : $" · Created by {_ranking.CreatedByName}")</MudText>
                </div>
            </div>

            <div class="d-flex flex-row align-center gap-3">
                <MudToggleGroup T="string?" Value="@_positionFilter" ValueChanged="@PositionFilterChanged"
                                Size="Size.Small" Color="Color.Primary">
                    <MudToggleItem T="string?" Value="@(null)" Text="All"/>
                    <MudToggleItem T="string?" Value="@Position.Forward" Text="F"/>
                    <MudToggleItem T="string?" Value="@Position.Defense" Text="D"/>
                    <MudToggleItem T="string?" Value="@Position.Goalie" Text="G"/>
                </MudToggleGroup>

                <MudToggleGroup T="ViewMode" Value="@_viewMode" ValueChanged="@ViewModeChanged"
                                Size="Size.Small" Color="Color.Primary">
                    <MudToggleItem T="ViewMode" Value="ViewMode.Grid">
                        <MudIcon Icon="@Icons.Material.Rounded.GridView" Size="Size.Small"/>
                    </MudToggleItem>
                    <MudToggleItem T="ViewMode" Value="ViewMode.List">
                        <MudIcon Icon="@Icons.Material.Rounded.ViewList" Size="Size.Small"/>
                    </MudToggleItem>
                </MudToggleGroup>

                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Rounded.ContentCopy"
                           OnClick="@CloneAsync">Make a copy</MudButton>
                @if (_ranking.CanEdit)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Rounded.Sync"
                               OnClick="@SyncAsync">Sync players</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Rounded.Share"
                               OnClick="@ShareAsync">Share</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Rounded.Save" Disabled="@(!_dirty)"
                               OnClick="@SaveAsync">Save</MudButton>
                }
                else
                {
                    <MudChip T="string" Icon="@Icons.Material.Rounded.Visibility" Size="Size.Small" Color="Color.Default">View only</MudChip>
                }
            </div>
        </div>

        @if (_viewMode == ViewMode.Grid)
        {
            <RankingGridView @ref="_gridView" Players="_players" CanEdit="@_ranking.CanEdit"
                             PositionFilter="@_positionFilter" OnChanged="@(() => _dirty = true)"/>
        }
        else
        {
        <MudDropContainer T="Sdk.CustomRankingPlayerDto" @ref="_dropContainer"
                          Items="_players"
                          ItemsSelector="@((item, zone) => _positionFilter is null || item.Player.Position == _positionFilter)"
                          ItemDropped="@ItemDropped"
                          Class="mud-width-full">
            <ChildContent>
                <MudDropZone T="Sdk.CustomRankingPlayerDto" Identifier="ranking" Class="mud-width-full"
                             AllowReorder="@_ranking.CanEdit"/>
            </ChildContent>
            <ItemRenderer>
                <MudPaper Class="@($"pa-3 my-1 d-flex flex-row align-center justify-space-between {(_ranking.CanEdit ? "cursor-grab" : string.Empty)}")"
                          Elevation="0" Square Outlined>
                    <div class="d-flex flex-row align-center gap-3">
                        @if (_ranking.CanEdit)
                        {
                            <MudIcon Icon="@Icons.Material.Rounded.DragIndicator" Color="Color.Default"/>
                        }
                        <MudText Typo="Typo.h6" Style="min-width: 2.5rem;">@context.Rank</MudText>
                        <PositionChip Position="@context.Player.Position" Variant="Variant.Text" Size="Size.Small"/>
                        <MudText Typo="Typo.body1"><b>@context.Player.FullName</b></MudText>
                    </div>
                    <div class="d-flex flex-row align-center gap-3">
                        <div class="d-flex flex-row align-center gap-4">
                            @StatLabel(context.PointsPerGame.ToString("F2"), "PPG")
                            @StatLabel(context.TotalPoints.ToString(), "P")
                            @StatLabel(context.GamesPlayed.ToString(), "GP")
                        </div>
                        @if (_ranking.CanEdit)
                        {
                            <MudButtonGroup OverrideStyles="false" Size="Size.Small">
                                <MudIconButton OnClick="@(_ => MoveToTop(context))" Icon="@Icons.Material.Rounded.KeyboardDoubleArrowUp" Disabled="@IsFirstVisible(context)"/>
                                <MudIconButton OnClick="@(_ => MoveUp(context))" Icon="@Icons.Material.Rounded.KeyboardArrowUp" Disabled="@IsFirstVisible(context)"/>
                                <MudIconButton OnClick="@(_ => MoveDown(context))" Icon="@Icons.Material.Rounded.KeyboardArrowDown" Disabled="@IsLastVisible(context)"/>
                                <MudIconButton OnClick="@(_ => MoveToBottom(context))" Icon="@Icons.Material.Rounded.KeyboardDoubleArrowDown" Disabled="@IsLastVisible(context)"/>
                            </MudButtonGroup>
                        }
                    </div>
                </MudPaper>
            </ItemRenderer>
        </MudDropContainer>
        }

        @if (_ranking.CanEdit && StaleVisible.Any())
        {
            <MudPaper Class="pa-3 mt-4" Elevation="0" Outlined>
                <div class="d-flex flex-row align-center gap-2 mb-2">
                    <MudIcon Icon="@Icons.Material.Rounded.WarningAmber" Color="Color.Warning"/>
                    <MudText Typo="Typo.subtitle1"><b>No longer in pool (@StaleVisible.Count())</b></MudText>
                </div>
                @foreach (var p in StaleVisible)
                {
                    <div class="d-flex flex-row align-center justify-space-between py-1" style="opacity: 0.6;">
                        <div class="d-flex flex-row align-center gap-3">
                            <PositionChip Position="@(p.Player.Position ?? string.Empty)" Variant="Variant.Text" Size="Size.Small"/>
                            <MudText Typo="Typo.body1">@p.Player.FullName</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Removed</MudChip>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => RemoveStale(p))"/>
                    </div>
                }
            </MudPaper>
        }
    }
</MudContainer>


@code {

    [Parameter]
    [EditorRequired]
    public required int Id { get; set; }

    private bool _loading = true;
    private bool _dirty;
    private string? _positionFilter;
    private ViewMode _viewMode = ViewMode.Grid;

    private Sdk.CustomRankingSingleDto? _ranking;
    private List<Sdk.CustomRankingPlayerDto> _players = [];
    private List<Sdk.CustomRankingPlayerDto> _stale = [];
    private MudDropContainer<Sdk.CustomRankingPlayerDto> _dropContainer = null!;
    private RankingGridView? _gridView;

    private enum ViewMode { List, Grid }

    private IEnumerable<Sdk.CustomRankingPlayerDto> StaleVisible =>
        _positionFilter is null ? _stale : _stale.Where(p => p.Player.Position == _positionFilter);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _ranking = await BoltonCupApi.GetCustomRankingByIdAsync(Id);
            Partition();
        }
        catch (Sdk.ApiException)
        {
            Navigation.NavigateTo("/rankings");
        }
        finally
        {
            _loading = false;
        }
    }

    private void Partition()
    {
        var all = _ranking?.Players ?? new List<Sdk.CustomRankingPlayerDto>();
        _players = all.Where(p => !p.IsStale).OrderBy(p => p.Rank).ToList();
        _stale = all.Where(p => p.IsStale).ToList();
    }

    private async Task RemoveStale(Sdk.CustomRankingPlayerDto player)
    {
        await BoltonCupApi.RemoveCustomRankingPlayerAsync(Id, player.Player.Id);
        _stale.Remove(player);
        Snackbar.Add($"Removed {player.Player.FullName}", Severity.Success);
    }

    private async Task SyncAsync()
    {
        var refreshed = await BoltonCupApi.ReconcileCustomRankingAsync(Id);
        var known = _players.Concat(_stale).Select(p => p.Player.Id).ToHashSet();

        // Merge in only the newcomers so any unsaved manual ordering is preserved. New players slot into
        // their default points-per-game position, matching the server-side reconcile.
        var added = 0;
        foreach (var p in refreshed.Players.OrderByDescending(p => p.PointsPerGame))
        {
            if (!known.Add(p.Player.Id))
                continue;
            if (p.IsStale)
            {
                _stale.Add(p);
            }
            else
            {
                var index = _players.FindIndex(e => e.PointsPerGame < p.PointsPerGame);
                if (index < 0)
                    _players.Add(p);
                else
                    _players.Insert(index, p);
            }
            added++;
        }

        if (added > 0)
        {
            RankingReorder.Renumber(_players);
            _dirty = true;
            RefreshActiveView();
        }

        Snackbar.Add(added == 0 ? "No new players" : $"Added {added} new player(s)", Severity.Info);
    }

    private void PositionFilterChanged(string? position)
    {
        _positionFilter = position;
        RefreshActiveView();
    }

    private void ViewModeChanged(ViewMode mode)
    {
        _viewMode = mode;
    }

    private void RefreshActiveView()
    {
        if (_viewMode == ViewMode.Grid)
            _gridView?.Refresh();
        else
            _dropContainer?.Refresh();
    }

    private bool IsFirstVisible(Sdk.CustomRankingPlayerDto player) => RankingReorder.IsFirstVisible(_players, player, _positionFilter);

    private bool IsLastVisible(Sdk.CustomRankingPlayerDto player) => RankingReorder.IsLastVisible(_players, player, _positionFilter);

    private void ItemDropped(MudItemDropInfo<Sdk.CustomRankingPlayerDto> info)
    {
        if (_ranking is not { CanEdit: true } || info.Item is null)
            return;

        RankingReorder.ReorderToVisibleIndex(_players, info.Item, info.IndexInZone, _positionFilter);
        _dirty = true;
        _dropContainer.Refresh();
    }

    private void MoveUp(Sdk.CustomRankingPlayerDto player) => ApplyMove(RankingReorder.MoveUp, player);

    private void MoveDown(Sdk.CustomRankingPlayerDto player) => ApplyMove(RankingReorder.MoveDown, player);

    private void MoveToTop(Sdk.CustomRankingPlayerDto player) => ApplyMove(RankingReorder.MoveToTop, player);

    private void MoveToBottom(Sdk.CustomRankingPlayerDto player) => ApplyMove(RankingReorder.MoveToBottom, player);

    private void ApplyMove(
        Action<List<Sdk.CustomRankingPlayerDto>, Sdk.CustomRankingPlayerDto, string?> move,
        Sdk.CustomRankingPlayerDto player)
    {
        move(_players, player, _positionFilter);
        _dirty = true;
        _dropContainer.Refresh();
    }

    private async Task SaveAsync()
    {
        await BoltonCupApi.UpdateCustomRankingAsync(Id, new Sdk.UpdateCustomRankingRequest
        {
            OrderedPlayerIds = _players.Select(p => p.Player.Id).ToList()
        });
        _dirty = false;
        Snackbar.Add("Ranking saved", Severity.Success);
    }

    private async Task CloneAsync()
    {
        if (_ranking is null)
            return;

        var parameters = new DialogParameters<CloneRankingDialog> { { x => x.SourceTitle, _ranking.Title } };
        var dialog = await DialogService.ShowAsync<CloneRankingDialog>("Make a copy", parameters);
        var result = await dialog.Result;
        if (result?.Data is string { Length: > 0 } title)
        {
            var newId = await BoltonCupApi.CloneCustomRankingAsync(Id, new Sdk.CloneCustomRankingRequest { Title = title });
            Navigation.NavigateTo($"/rankings/{newId}", true);
        }
    }

    private async Task ShareAsync()
    {
        var parameters = new DialogParameters<ShareRankingDialog> { { x => x.RankingId, Id } };
        await DialogService.ShowAsync<ShareRankingDialog>("Share ranking", parameters);
    }

    private RenderFragment StatLabel(string value, string label) =>
        @<div>
            <MudText Typo="Typo.subtitle2" Align="Align.Center">@value</MudText>
            <MudText Typo="Typo.caption" Align="Align.Center">@label</MudText>
        </div>;
}
