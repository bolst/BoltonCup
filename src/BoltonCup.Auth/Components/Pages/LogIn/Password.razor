@page "/log-in/password"
@implements IDisposable
@inject AuthSessionStateService AuthSessionState
@inject ISnackbar Snackbar
@inject IBoltonCupApi BoltonCupApi
@inject IDialogService DialogService

<AuthSession>
    <AutoEditForm T="LogInWithPasswordFormModel" EditContext="_editContext" OnValidSubmit="OnSubmit" Title="Enter your password" ShowForgotPasswordLink />
</AuthSession>


@code {
    
    private readonly LogInWithPasswordFormModel _model = new();
    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;


    protected override void OnInitialized() 
    {
        _model.Email = AuthSessionState.Context.Email ?? string.Empty;

        _editContext = new EditContext(_model);
        _editContext.OnValidationRequested += HandleValidationRequested;
        _messageStore = new ValidationMessageStore(_editContext);
    }
    
    private void HandleValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        _messageStore?.Clear();
    }

    private async Task OnSubmit(EditContext _)
    {
        try
        {
            var delayTask = Task.Delay(3000); // load for 3 seconds minimum
            var loginTask = LoginAsync();
            await Task.WhenAll(delayTask, loginTask);
            AuthSessionState.NavigateToReturnUrlOrDefault();
        }
        catch (ApiException e)
            when (e.StatusCode == 401)
        {
            _messageStore?.Add(() => _model.Password, "Invalid password.");
            _editContext?.NotifyValidationStateChanged();
        }
        catch (ApiException e)
            when (e.StatusCode == 403)
        {
            await BoltonCupApi.ResendConfirmationEmailAsync(new ResendConfirmationEmailRequest
            {
                Email = _model.Email,
            });
            var dialog = await DialogService.ShowAsync<ConfirmAccountDialog>("Confirm Account", new DialogParameters<ConfirmAccountDialog>
            {
                { x => x.Context, AuthSessionState.Context }
            });
            var result = await dialog.Result;
            if (result?.Data is not bool status)
                return;
            if (status)
            {
                await LoginAsync();
                AuthSessionState.NavigateToReturnUrlOrDefault();
            }
        }
        catch (ApiException e)
            when (e.StatusCode == 429)
        {
            _messageStore?.Add(() => _model.Password, "You made too many requests! Try again later.");
            _editContext?.NotifyValidationStateChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add("An unexpected error occurred.", Severity.Error);
        }
    }

    private Task LoginAsync()
    {
        return BoltonCupApi.LoginWithCookieAsync(new LoginWithCookieRequest
        {
            Email = _model.Email,
            Password = _model.Password,
            Persist = true, // TODO: "remember me?"
        });   
    }
    
    public void Dispose()
    {
        if (_editContext != null)
        {
            _editContext.OnValidationRequested -= HandleValidationRequested;
        }
    }

}