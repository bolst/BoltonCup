@page "/create-account/password"
@using BoltonCup.Common
@implements IDisposable
@inject AuthSessionStateService AuthSessionState
@inject IBoltonCupApi BoltonCupApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<AuthSession>
    <AutoEditForm T="CreateAccountWithPasswordFormModel" EditContext="_editContext" OnValidSubmit="OnSubmit" Title="Create a password" />
</AuthSession>


@code {
    
    private readonly CreateAccountWithPasswordFormModel _model = new();
    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;


    protected override void OnInitialized() 
    {
        _model.Email = AuthSessionState.Context.Email ?? string.Empty;

        _editContext = new EditContext(_model);
        _editContext.OnValidationRequested += HandleValidationRequested;
        _messageStore = new ValidationMessageStore(_editContext);
    }
    
    private void HandleValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        _messageStore?.Clear();
    }

    private async Task OnSubmit(EditContext _)
    {
        try
        {
            var delayTask = Task.Delay(3000); // load for 3 seconds minimum
            var signUpTask = BoltonCupApi.RegisterAsync(new RegisterRequest
            {
                Email = _model.Email,
                Password = _model.Password
            });
            await Task.WhenAll(delayTask, signUpTask);

            await TryConfirmEmailAsync();
        }
        catch (ApiException<BoltonCupProblemDetails> e)
        {
            Snackbar.Add(e.Result.Detail, Severity.Error);
        }
        catch (ApiException<BoltonCupValidationProblemDetails> e)
        {
            var identifier = new FieldIdentifier(_model, nameof(_model.Password));
            _messageStore?.Add(identifier, e.Result.Detail);
            _editContext?.NotifyValidationStateChanged();
        }
    }

    private async Task TryConfirmEmailAsync()
    {
        var dialog = await DialogService.ShowAsync<ConfirmAccountDialog>("Confirm Account", new DialogParameters<ConfirmAccountDialog>
        {
            { x => x.Context, AuthSessionState.Context }
        });
        
        if (await dialog.Result is {  Data: true })
        {
            try
            {
                await BoltonCupApi.LoginAsync(new LoginRequest
                {
                    Email = _model.Email,
                    Password = _model.Password,
                    Persist = true,
                });
                AuthSessionState.NavigateToReturnUrlOrDefault();
            }
            catch // we should never get here, but just in case...
            {
                await AuthSessionState.LogInOrSignUpAsync();
            }
        }
    }
    
    public void Dispose()
    {
        if (_editContext != null)
        {
            _editContext.OnValidationRequested -= HandleValidationRequested;
        }
    }

}