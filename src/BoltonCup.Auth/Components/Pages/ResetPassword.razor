@page "/reset-password"
@inject AuthSessionStateService AuthSessionState
@inject IBoltonCupApi BoltonCupApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Reset Password | Bolton Cup</PageTitle>

<AuthSession>
    <MudText Typo="Typo.h4">Reset password</MudText>
    <MudStack Spacing="6" AlignItems="AlignItems.Center" Class="mud-width-full">
        <MudText Typo="Typo.body1" Align="Align.Center">
            Click "Continue" to reset your password for
            <MudText Typo="Typo.body1">@AuthSessionState.Email</MudText>
        </MudText>
        
        <MudButton OnClick="OnContinue" Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" Disabled="_isSubmitting" FullWidth>Continue</MudButton>
        
        <MudLink Href="/log-in-or-sign-up">Back to login</MudLink>
    </MudStack>
</AuthSession>


@code {

    private bool _isSubmitting;
    
    private async Task OnContinue()
    {
        _isSubmitting = true;

        var delayTask = Task.Delay(300);
        try
        {
            await BoltonCupApi.ForgotPasswordAsync(new ForgotPasswordRequest
            {
                Email = AuthSessionState.Email
            });
            await delayTask;
            Navigation.NavigateTo("/email-verification");
        }
        catch
        {
            Snackbar.Add("Something went wrong...", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

}