@page "/reset-password"
@inject AuthSessionStateService AuthSessionState
@inject IBoltonCupApi BoltonCupApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Reset Password | Bolton Cup</PageTitle>

<AuthSession>
    <MudText Typo="Typo.h4">Reset password</MudText>
    <MudStack Spacing="6" AlignItems="AlignItems.Center" Class="mud-width-full">
        <MudText Typo="Typo.body1" Align="Align.Center">
            Click "Continue" to reset your password for
            <MudText Typo="Typo.body1">@AuthSessionState.Context.Email</MudText>
        </MudText>
        
        <MudButton OnClick="OnContinue" Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" Disabled="_isSubmitting" FullWidth>Continue</MudButton>
        
        <MudLink Href="/log-in-or-sign-up">Back to login</MudLink>
    </MudStack>
</AuthSession>


@code {

    private bool _isSubmitting;
    
    private async Task OnContinue()
    {
        _isSubmitting = true;

        var delayTask = Task.Delay(300);
        try
        {
            await BoltonCupApi.ForgotPasswordV2Async(new ForgotPasswordV2Request
            {
                Email = AuthSessionState.Context.Email
            });
            await delayTask;

            var dialog = await DialogService.ShowAsync<PasswordResetDialog>("Verify Email",
                new DialogParameters<PasswordResetDialog>
                {
                    { x => x.Context, AuthSessionState.Context },
                });
            var result = await dialog.Result;
            if (result?.Data is not bool status)
                return;
            if (status)
                await AuthSessionState.LogInOrSignUp();
        }
        catch
        {
            Snackbar.Add("Something went wrong...", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

}