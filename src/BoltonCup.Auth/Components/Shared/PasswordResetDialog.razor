@implements IDisposable
@inject ISnackbar Snackbar
@inject IBoltonCupApi BoltonCupApi

<MudDialog>
    <DialogContent>
        <MudContainer Class="py-8" MaxWidth="MaxWidth.Small" Gutters="false">
            @if (_isValidCode)
            {
                <AutoEditForm T="NewPasswordFormModel" EditContext="_passwordEditContext" OnValidSubmit="OnPasswordSubmit" Title="Enter a new password" />
            }
            else
            {
                <AutoEditForm T="EmailVerificationFormModel" EditContext="_verifyEditContext" OnValidSubmit="OnCodeSubmit" Title="Check your inbox">
                    <ActionsContent>
                        <MudStack Spacing="6" AlignItems="AlignItems.Center" Class="mud-width-full">
                            <MudText Typo="Typo.body1" Align="Align.Center">
                                Enter the verification code we just sent to
                                <MudText Typo="Typo.body1">@Context.Email</MudText>
                            </MudText>

                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" Disabled="_isSubmitting" FullWidth>Continue</MudButton>

                            <MudLink OnClick="ResendEmail">Resend email</MudLink>

                            @* <MudText><b>OR</b></MudText> *@
                            @* <MudButton OnClick="ContinueWithPassword" Variant="Variant.Outlined" Size="Size.Large" Color="Color.Primary" Disabled="_isSubmitting" FullWidth> *@
                            @*     Continue with password *@
                            @* </MudButton> *@
                        </MudStack>
                    </ActionsContent>
                </AutoEditForm>
            }
        </MudContainer>
    </DialogContent>
</MudDialog>


@code {

    [CascadingParameter] 
    private IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter]
    [EditorRequired]
    public required IAuthSessionContext Context { get; set; }

    private bool _isValidCode;
    private bool _isSubmitting;
    
    private readonly EmailVerificationFormModel _verifyModel = new();
    private EditContext? _verifyEditContext;
    private ValidationMessageStore? _verifyMessageStore;
    
    private readonly NewPasswordFormModel _passwordModel = new();
    private EditContext? _passwordEditContext;
    private ValidationMessageStore? _passwordMessageStore;


    protected override Task OnInitializedAsync() 
    {
        _verifyEditContext = new EditContext(_verifyModel);
        _verifyEditContext.OnValidationRequested += HandleVerifyValidationRequested;
        _verifyMessageStore = new ValidationMessageStore(_verifyEditContext);
        
        _passwordEditContext = new EditContext(_passwordModel);
        _passwordEditContext.OnValidationRequested += HandlePasswordValidationRequested;
        _passwordMessageStore = new ValidationMessageStore(_passwordEditContext);

        return MudDialog.SetOptionsAsync(MudDialog.Options with
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = false,
            BackdropClick = false,
            NoHeader = true,
        });
    }
    
    private void HandleVerifyValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        _verifyMessageStore?.Clear();
    }
    
    private void HandlePasswordValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        _passwordMessageStore?.Clear();
    }

    private async Task OnCodeSubmit(EditContext _)
    {
        try
        {
            _isSubmitting = true;
            _isValidCode = false;
            await BoltonCupApi.VerifyPasswordResetCodeAsync(new VerifyPasswordResetCodeRequest
            {
                Email = Context.Email,
                Code = _verifyModel.Code
            });
            _isValidCode = true;
        }
        catch (ApiException e)
            when (e.StatusCode is 400)
        {
            _verifyMessageStore?.Add(() => _verifyModel.Code, "That code is incorrect.");
            _verifyEditContext?.NotifyValidationStateChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add("An unexpected error occurred.", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnPasswordSubmit(EditContext _)
    {
        try
        {
            _isSubmitting = true;
            await BoltonCupApi.ResetPasswordAsync(new ResetPasswordRequest
            {
                Email = Context.Email,
                ResetCode = _verifyModel.Code,
                NewPassword = _passwordModel.Password,
            });
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (ApiException<BoltonCupProblemDetails> e)
        when (e.Result.Type == ErrorTypes.Auth.InvalidCredentials)
        {
            _passwordMessageStore?.Add(() => _passwordModel.ConfirmPassword, "Could not reset with this password...");
            _passwordEditContext?.NotifyValidationStateChanged();
        }
        catch (Exception e)
        {
            Snackbar.Add("An unexpected error occurred.", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    
    private async Task ResendEmail()
    {
        _isSubmitting = true;
        _isValidCode = false;

        try
        {
            var delayTask = Task.Delay(300);
            await BoltonCupApi.ForgotPasswordAsync(new ForgotPasswordRequest
            {
                Email = Context.Email
            });
            await delayTask;
            Snackbar.Add($"If an account exists, an email with a code has been sent to {Context.Email}.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Something went wrong...", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    
    public void Dispose()
    {
        if (_verifyEditContext != null)
        {
            _verifyEditContext.OnValidationRequested -= HandleVerifyValidationRequested;
        }

        if (_passwordEditContext != null)
        {
            _passwordEditContext.OnValidationRequested -= HandlePasswordValidationRequested;
        }
    }

}