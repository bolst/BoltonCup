@implements IDisposable
@inject ISnackbar Snackbar
@inject IBoltonCupApi BoltonCupApi

<MudDialog>
    <DialogContent>
        <MudContainer Class="py-8" MaxWidth="MaxWidth.Small" Gutters="false">
            <AutoEditForm T="EmailVerificationFormModel" EditContext="_editContext" OnValidSubmit="OnSubmit" Title="Check your inbox">
                <ActionsContent>
                    <MudStack Spacing="6" AlignItems="AlignItems.Center" Class="mud-width-full">
                        <MudText Typo="Typo.body1" Align="Align.Center">
                            To confirm your account, enter the verification code we just sent to
                            <MudText Typo="Typo.body1">@Context.Email</MudText>
                        </MudText>

                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" Disabled="_isSubmitting" FullWidth>Continue</MudButton>

                        <MudLink OnClick="ResendEmail">Resend email</MudLink>
                    </MudStack>
                </ActionsContent>
            </AutoEditForm>
        </MudContainer>
    </DialogContent>
</MudDialog>


@code {

    [CascadingParameter] 
    private IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter]
    [EditorRequired]
    public required IAuthSessionContext Context { get; set; }

    private bool _isSubmitting;
    
    private readonly EmailVerificationFormModel _model = new();
    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;


    protected override Task OnInitializedAsync() 
    {
        _editContext = new EditContext(_model);
        _editContext.OnValidationRequested += HandleValidationRequested;
        _messageStore = new ValidationMessageStore(_editContext);

        return MudDialog.SetOptionsAsync(MudDialog.Options with
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = false,
            BackdropClick = false,
            NoHeader = true,
        });
    }
    
    private void HandleValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        _messageStore?.Clear();
    }
    
    private async Task OnSubmit(EditContext _)
    {
        try
        {
            _isSubmitting = true;
            await BoltonCupApi.ConfirmEmailAsync(new ConfirmEmailRequest
            {
                Email = Context.Email,
                Code = _model.Code,
            });
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (ApiException<BoltonCupProblemDetails> e)
            when (e.Result.Type == ErrorTypes.Auth.InvalidCredentials)
        {
            _messageStore?.Add(() => _model.Code, "That code is incorrect.");
            _editContext?.NotifyValidationStateChanged();
        }
        finally
        {
            _isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ResendEmail()
    {
        _isSubmitting = true;

        try
        {
            var delayTask = Task.Delay(300);
            await BoltonCupApi.ResendConfirmationEmailAsync(new ResendConfirmationEmailRequest
            {
                Email = Context.Email
            });
            await delayTask;
            Snackbar.Add($"An email with a code has been sent to {Context.Email}.", Severity.Success);
        }
        finally
        {
            _isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    
    public void Dispose()
    {
        if (_editContext != null)
        {
            _editContext.OnValidationRequested -= HandleValidationRequested;
        }
    }

}