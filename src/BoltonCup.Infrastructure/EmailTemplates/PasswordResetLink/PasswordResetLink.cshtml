@using BoltonCup.Infrastructure.EmailTemplates
@using Microsoft.AspNetCore.Html
@model PasswordResetLinkViewModel
@{
    // ReSharper disable once Razor.LayoutNotResolved
    Layout = EmailConstants.SharedLayout;
}

<p style="font-size: 14px; color: #555555;">Please reset your password with the following:</p>

<a href="@(new HtmlString(Model.ResetLink))" style="display: inline-block; background-color: #353535; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 16px; margin: 20px 0;">
    Reset Password
</a>

<p>
    Or paste this link into your browser:
    <br>
    <p style="text-decoration: underline">
        @(new HtmlString(Model.ResetLink))
    </p>
</p>


