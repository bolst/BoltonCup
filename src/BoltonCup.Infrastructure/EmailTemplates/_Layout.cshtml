<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 20px; }
        .email-container { max-width: 600px; margin: 0 auto; background: #ffffff; padding: 20px; border-radius: 8px; }
        .header { text-align: center; padding-bottom: 20px; border-bottom: 1px solid #eeeeee; }
        .footer { text-align: center; font-size: 12px; color: #888888; margin-top: 20px; }
    </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f7f7f7;">
    <div class="email-container">
        <div class="header">
            <h2>Bolton Cup</h2>
        </div>

        @RenderBody()

        <div class="footer">
            <p>&copy; @DateTime.UtcNow.Year Bolton Cup. All rights reserved.</p>
            <p>You are receiving this email because you registered an account with us.</p>
        </div>
        <div style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 600px; margin: 0 auto; padding: 0 40px 40px 40px; text-align: center; color: #999999; font-size: 14px;">
            <p style="margin: 0 0 10px 0;">You are receiving this because of a login attempt on your account.</p>
            <p style="margin: 0;">
                <a href="https://boltoncup.ca/unsubscribe" style="color: #999999; text-decoration: underline;">Unsubscribe</a> &bull;
                <a href="https://boltoncup.ca/privacy-policy" style="color: #999999; text-decoration: underline;">Privacy Policy</a>
            </p>
        </div>
    </div>
</body>
</html>