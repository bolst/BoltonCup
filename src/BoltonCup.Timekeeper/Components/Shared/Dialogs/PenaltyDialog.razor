@namespace BoltonCup.Timekeeper.Components.Shared

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-1">

            <MudText Typo="Typo.subtitle1" Class="mb-1">Which team took the penalty?</MudText>
            <div class="d-flex flex-row gap-2">
                <MudButton Variant="@(_homeSelected ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           FullWidth
                           OnClick="@(() => SelectTeam(true))">
                    @(HomeTeam?.NameShort ?? "Home")
                </MudButton>
                <MudButton Variant="@(!_homeSelected ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Secondary"
                           FullWidth
                           OnClick="@(() => SelectTeam(false))">
                    @(AwayTeam?.NameShort ?? "Away")
                </MudButton>
            </div>

            <MudAutocomplete T="PlayerDto"
                             Label="Player"
                             @bind-Value="_player"
                             SearchFunc="@SearchPlayer"
                             ToStringFunc="@PlayerLabel"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             ResetValueOnEmptyText
                             Required />

            <MudSelect T="string"
                       Label="Infraction"
                       @bind-Value="_infraction"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Required>
                @foreach (var infraction in Infractions)
                {
                    <MudSelectItem Value="@infraction">@infraction</MudSelectItem>
                }
            </MudSelect>

            <div class="d-flex flex-row gap-2">
                <MudSelect T="int"
                           Label="Duration"
                           @bind-Value="_duration"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="flex-grow-0" Style="min-width: 120px">
                    @foreach (var min in DurationOptions)
                    {
                        <MudSelectItem Value="@min">@min min</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int"
                           Label="Period"
                           @bind-Value="_period"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="flex-grow-0" Style="min-width: 100px">
                    @foreach (var (val, label) in PeriodOptions)
                    {
                        <MudSelectItem Value="@val">@label</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField Label="Time Remaining"
                              @bind-Value="_timeRemaining"
                              Placeholder="mm:ss"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              HelperText="e.g. 12:35"
                              Class="flex-grow-1" />
            </div>

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Dialog.Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!CanSubmit)"
                   OnClick="@Submit">
            Record Penalty
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    public IMudDialogInstance Dialog { get; set; } = null!;

    [Parameter] public TeamInGameDto? HomeTeam { get; set; }
    [Parameter] public TeamInGameDto? AwayTeam { get; set; }
    [Parameter] public List<PlayerDto> HomePlayers { get; set; } = [];
    [Parameter] public List<PlayerDto> AwayPlayers { get; set; } = [];
    [Parameter] public int CurrentPeriod { get; set; } = 1;

    private static readonly (int Value, string Label)[] PeriodOptions =
    [
        (1, "1st"), (2, "2nd"), (3, "3rd"), (4, "OT"),
    ];

    private static readonly int[] DurationOptions = [2, 4, 5, 10];

    private static readonly string[] Infractions =
    [
        "Tripping",
        "Hooking",
        "Holding",
        "Interference",
        "High Sticking",
        "Roughing",
        "Cross-Checking",
        "Slashing",
        "Boarding",
        "Charging",
        "Elbowing",
        "Delay of Game",
        "Too Many Men",
        "Unsportsmanlike Conduct",
        "Fighting",
        "Misconduct",
        "Game Misconduct",
    ];

    private bool _homeSelected = true;
    private PlayerDto? _player;
    private string? _infraction;
    private int _duration = 2;
    private int _period;
    private string _timeRemaining = "00:00";

    private bool CanSubmit => _player is not null && !string.IsNullOrWhiteSpace(_infraction);

    private List<PlayerDto> ActiveRoster => _homeSelected ? HomePlayers : AwayPlayers;

    protected override void OnInitialized()
    {
        _period = CurrentPeriod;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Dialog.SetOptionsAsync(Dialog.Options with
        {
            CloseOnEscapeKey = true,
            BackdropClick = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
        });
    }

    private void SelectTeam(bool home)
    {
        if (_homeSelected == home) return;
        _homeSelected = home;
        _player = null;
    }

    private static string PlayerLabel(PlayerDto? p) =>
        p is null ? string.Empty : $"#{p.JerseyNumber?.ToString() ?? "-"} {p.FirstName} {p.LastName}".Trim();

    private Task<IEnumerable<PlayerDto>> SearchPlayer(string? value, CancellationToken ct)
    {
        var roster = (IEnumerable<PlayerDto>)ActiveRoster;
        if (!string.IsNullOrWhiteSpace(value))
        {
            var lower = value.ToLowerInvariant();
            roster = roster.Where(p => PlayerLabel(p).ToLowerInvariant().Contains(lower));
        }
        return Task.FromResult(roster);
    }

    private void Submit()
    {
        if (!CanSubmit) return;
        if (!TryParseTime(_timeRemaining, out var ts)) ts = TimeSpan.Zero;

        var request = new CreatePenaltyRequest
        {
            TeamId = _homeSelected ? (HomeTeam?.Id ?? 0) : (AwayTeam?.Id ?? 0),
            Period = _period,
            PeriodLabel = TimekeeperStateService.PeriodLabel(_period),
            PeriodTimeRemaining = ts.ToString("c"),
            PlayerId = _player!.Id,
            InfractionName = _infraction!,
            DurationMinutes = _duration,
        };
        Dialog.Close(DialogResult.Ok(request));
    }

    private static bool TryParseTime(string input, out TimeSpan result)
    {
        if (TimeSpan.TryParseExact(input, @"mm\:ss", null, out result)) return true;
        if (TimeSpan.TryParseExact(input, @"m\:ss", null, out result)) return true;
        result = TimeSpan.Zero;
        return false;
    }

}
