# Copy to .env and fill in. Never commit the real .env.

# Base URL of the BoltonCup Web API. Must be the API's Tailscale address
# (MagicDNS name or 100.x IP) — the admin key is rejected from non-tailnet sources.
BC_API_BASE=http://boltoncup-api.your-tailnet.ts.net:8080

# Admin API key. Must match the API's BoltonCup:Authentication:AdminApiKey.
# Sent as the BoltonCup-Api-Key header; grants admin access (no login needed).
# The API must also have BoltonCup:Authentication:AdminAccountId set so the key
# can reach the upload-credentials endpoint.
BC_API_KEY=change-me

# Tournament to drain.
BC_TOURNAMENT_ID=1

# Spotify app credentials (https://developer.spotify.com/dashboard).
# Used for metadata lookup and by spotDL.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: seconds to pause between tracks (default 2).
# BC_TRACK_DELAY=2
