@page "/auth/callback/googlesignin"

@inject Supabase.Client SBClient
@inject NavigationManager Navigation
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject Data.CustomAuthenticationStateProvider AuthStateProvider

@code {

    [SupplyParameterFromQuery(Name = "code")]
    public string Code { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string? verifier = await LocalStorage.GetItemAsStringAsync("verifier");
            if (!string.IsNullOrEmpty(Code) && !string.IsNullOrEmpty(verifier))
            {
                var session = await SBClient.Auth.ExchangeCodeForSession(verifier, Code);
                await LocalStorage.RemoveItemAsync("verifier");
                Navigation.NavigateTo("/");
            }
            else
            {
                Navigation.NavigateTo("/auth/signin", options: new() { ReplaceHistoryEntry = true });
            }
        }
    }
}
