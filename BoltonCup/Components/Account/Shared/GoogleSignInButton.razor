@using Supabase.Gotrue
@inject Supabase.Client SBClient
@inject NavigationManager Navigation
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject Data.CustomUserService UserService

<MudButton Class="pa-2" Style="background-color: #4285F4; color: white;" StartIcon="@Icons.Custom.Brands.Google"
    OnClick="GoogleSignIn" FullWidth>
    Continue with Google</MudButton>

@code {
    private async Task GoogleSignIn()
    {
        await UserService.SignInWithGoogleAsync();
    }
}